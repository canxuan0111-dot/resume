---
/**
 * SectionHeader — 楼层标题区
 *
 * Props:
 *   eyebrow   — 顶部小标签（全大写，蓝色）
 *   title     — 主标题（支持 HTML，用 set:html 注入）
 *   subtitle  — 副标题/描述（可选）
 *   weight    — 'editorial'（400，首页轻盈风）| 'bold'（700，项目页重感）
 *   align     — 'left'（默认）| 'center'
 *   theme     — 'light'（默认，深色文字）| 'dark'（白色文字，用于深色背景）
 *   reveal    — 是否加 reveal 动画（默认 true）
 */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  weight?: 'editorial' | 'bold';
  align?: 'left' | 'center';
  theme?: 'light' | 'dark';
  reveal?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  weight = 'bold',
  align = 'left',
  theme = 'light',
  reveal = true,
} = Astro.props;

const revealClass = reveal ? 'reveal' : '';
---

<div class:list={['sh', `sh--${align}`, `sh--${theme}`]}>
  {eyebrow && (
    <p class:list={['sh-eyebrow', revealClass]}>{eyebrow}</p>
  )}
  <h2
    class:list={['sh-title', `sh-title--${weight}`, revealClass, reveal ? 'reveal-delay-1' : '']}
    set:html={title}
  />
  {subtitle && (
    <p class:list={['sh-subtitle', revealClass, reveal ? 'reveal-delay-2' : '']}>{subtitle}</p>
  )}
</div>

<style>
.sh { margin-bottom: 48px; }
.sh--center { text-align: center; }
.sh--center .sh-subtitle { margin-left: auto; margin-right: auto; }

/* ── Eyebrow ── */
.sh-eyebrow {
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 16px;
}
.sh--dark .sh-eyebrow { color: var(--muted-inv); }

/* ── Title ── */
.sh-title {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 56px);
  letter-spacing: -.03em;
  line-height: 1.08;
  color: var(--text);
  margin-bottom: 16px;
}

.sh-title--editorial {
  font-weight: 400;
  letter-spacing: -.04em;
  font-size: clamp(36px, 5vw, 64px);
}

.sh-title--bold {
  font-weight: 700;
}

.sh--dark .sh-title { color: var(--text-inv); }

/* ── Subtitle ── */
.sh-subtitle {
  font-size: 16px;
  color: var(--muted);
  line-height: 1.75;
  max-width: 560px;
  margin-bottom: 0;
}
.sh--dark .sh-subtitle { color: var(--muted-inv); }
</style>
