---
interface Props {
  title?: string;
  description?: string;
  navPill?: boolean;
}

const { title = '李灿轩', description = '李灿轩 · AI 产品经理 · 6年经验', navPill = false } = Astro.props;
const path = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · 李灿轩</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Color tokens ── */
      --bg: #ffffff;
      --bg-alt: #f0f0f0;
      --surface: #f7f7f5;
      --canvas-dark: #0a0a0a;
      --text: #0a0a0a;
      --text-inv: #ffffff;
      --muted: rgba(10,10,10,0.45);
      --muted-inv: rgba(255,255,255,0.45);
      --border: rgba(0,0,0,0.08);
      --border-mid: rgba(0,0,0,0.13);
      --border-inv: rgba(255,255,255,0.1);
      --accent: #0062ff;
      --accent-bg: rgba(0,98,255,0.07);
      --accent-border: rgba(0,98,255,0.2);
      --red: #f9442c;
      --green: #00a854;
      --green-bg: rgba(0,168,84,0.07);
      --green-border: rgba(0,168,84,0.2);
      --amber: #d97706;
      --amber-bg: rgba(217,119,6,0.07);
      --amber-border: rgba(217,119,6,0.2);

      /* ── Radius ── */
      --radius: 12px;
      --radius-lg: 20px;
      --radius-pill: 100px;

      /* ── Spacing scale ── */
      --sp-xs: 8px;
      --sp-sm: 16px;
      --sp-md: 32px;
      --sp-lg: 64px;
      --sp-xl: 120px;

      /* ── Typography ── */
      --font-sans: 'Inter', -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
      --font-display: 'Syne', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Navbar（普通页面）── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: 60px;
      background: rgba(255,255,255,0.85);
      backdrop-filter: saturate(180%) blur(20px);
      -webkit-backdrop-filter: saturate(180%) blur(20px);
      border-bottom: 1px solid transparent;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 40px;
      transition: border-color .3s, background .3s, transform .42s cubic-bezier(.4,0,.2,1);
    }

    nav.scrolled {
      border-bottom-color: var(--border);
    }

    /* 普通页面向下滑时隐藏 */
    nav:not(.nav-pill).nav-collapsed {
      transform: translateY(-100%);
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -.3px;
      color: var(--text);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-size: 13.5px;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
      letter-spacing: -.1px;
    }

    .nav-links a:hover { color: var(--text); }
    .nav-links a.active { color: var(--text); }

    /* ── Nav: pill variant（首页居中胶囊）── */
    nav.nav-pill {
      top: 16px;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      width: auto;
      height: 44px;
      border-radius: 100px;
      padding: 0 20px;          /* 去掉 logo 后两侧等距 */
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: none;
      box-shadow: 0 2px 24px rgba(0,0,0,0.14);
      overflow: hidden;
      /* 收缩动画 */
      transition:
        transform   .46s cubic-bezier(.4,0,.2,1),
        height      .46s cubic-bezier(.4,0,.2,1),
        padding     .46s cubic-bezier(.4,0,.2,1),
        box-shadow  .4s,
        opacity     .35s;
    }

    /* 隐藏 logo（首页 pill 不需要）*/
    nav.nav-pill .nav-logo { display: none; }

    nav.nav-pill .nav-links {
      gap: 28px;                /* links 间距 */
      transition: opacity .18s;
    }
    nav.nav-pill .nav-links a { color: rgba(0,0,0,0.5); }
    nav.nav-pill .nav-links a:hover,
    nav.nav-pill .nav-links a.active { color: #0a0a0a; }

    /* ── Pill 收缩态 ── */
    nav.nav-pill.nav-collapsed {
      transform: translateX(-50%) scaleX(0.28) scaleY(0.14);
      opacity: 0.55;
      box-shadow: 0 1px 6px rgba(0,0,0,0.1);
      cursor: pointer;
    }

    nav.nav-pill.nav-collapsed:hover {
      opacity: 0.8;
    }

    nav.nav-pill.nav-collapsed .nav-links {
      opacity: 0;
      pointer-events: none;
      transition: opacity .1s;
    }

    /* pill 在 hero 上不变透明，保持白色 */
    nav.nav-pill.nav-hero {
      background: rgba(255,255,255,0.95) !important;
      border-bottom-color: transparent !important;
    }
    nav.nav-pill.nav-hero .nav-links a { color: rgba(0,0,0,0.5) !important; }
    nav.nav-pill.nav-hero .nav-links a:hover,
    nav.nav-pill.nav-hero .nav-links a.active { color: #0a0a0a !important; }

    /* ── Nav: hero variant (透明白字，非 pill 页面用）── */
    nav.nav-hero {
      background: transparent !important;
      border-bottom-color: transparent !important;
    }
    nav.nav-hero .nav-logo,
    nav.nav-hero .nav-links a {
      color: rgba(255,255,255,0.75);
    }
    nav.nav-hero .nav-links a:hover,
    nav.nav-hero .nav-links a.active {
      color: #fff;
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 0;
    }

    /* ── Section shared ── */
    .section {
      max-width: 1080px;
      margin: 0 auto;
      padding: 120px 40px;
    }

    .section-label {
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 18px;
    }

    .section-headline {
      font-family: 'Syne', sans-serif;
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 700;
      letter-spacing: -.03em;
      line-height: 1.08;
      color: var(--text);
      margin-bottom: 20px;
    }

    .section-sub {
      font-size: 17px;
      color: var(--muted);
      line-height: 1.75;
      max-width: 600px;
    }

    /* ── Scroll reveal ── */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity .7s cubic-bezier(.25,.46,.45,.94), transform .7s cubic-bezier(.25,.46,.45,.94);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: .08s; }
    .reveal-delay-2 { transition-delay: .16s; }
    .reveal-delay-3 { transition-delay: .24s; }
    .reveal-delay-4 { transition-delay: .32s; }
    .reveal-delay-5 { transition-delay: .40s; }
    .reveal-delay-6 { transition-delay: .48s; }

    /* ── Animations ── */
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 40px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      font-size: 13px;
      color: var(--muted);
    }

    .footer-left { display: flex; align-items: center; gap: 6px; }
    .footer-left strong { color: var(--text); font-weight: 600; }
    .footer-right { font-size: 12px; }

    /* ── WeChat Modal ── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background: rgba(0,0,0,0.4);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s cubic-bezier(.25,.46,.45,.94);
    }

    .modal-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .modal-box {
      background: #fff;
      border: 1px solid var(--border-mid);
      border-radius: 24px;
      padding: 40px 36px 32px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      max-width: 300px;
      width: 100%;
      transform: scale(.95) translateY(12px);
      transition: transform .3s cubic-bezier(.34,1.56,.64,1);
      box-shadow: 0 24px 80px rgba(0,0,0,0.15);
    }

    .modal-overlay.open .modal-box {
      transform: scale(1) translateY(0);
    }

    .modal-wechat-icon {
      width: 44px;
      height: 44px;
      background: #07c160;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-wechat-icon svg { width: 26px; height: 26px; fill: #fff; }

    .modal-title {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
    }

    .modal-sub {
      font-size: 13px;
      color: var(--muted);
      text-align: center;
      margin-top: -6px;
    }

    .qr-wrap {
      background: #f7f7f5;
      border-radius: 16px;
      padding: 12px;
      width: 190px;
      height: 190px;
    }

    .qr-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 6px;
      display: block;
    }

    .modal-close {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--muted);
      border-radius: 100px;
      padding: 8px 24px;
      font-size: 13px;
      cursor: pointer;
      transition: all .2s;
      font-family: inherit;
    }

    .modal-close:hover {
      background: var(--border);
      color: var(--text);
    }

    /* ── Hamburger ── */
    .nav-menu-btn {
      display: none;
      width: 36px;
      height: 36px;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      border-radius: 8px;
      flex-shrink: 0;
    }

    .nav-menu-btn span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--text);
      border-radius: 2px;
      transform-origin: center;
      transition: transform .28s cubic-bezier(.25,.46,.45,.94), opacity .2s;
    }

    .nav-menu-btn.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav-menu-btn.open span:nth-child(2) { opacity: 0; }
    .nav-menu-btn.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    nav.nav-hero .nav-menu-btn span { background: rgba(255,255,255,0.8); }

    /* ── Mobile menu ── */
    .nav-mobile-menu {
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      z-index: 98;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 4px 20px 20px;
      opacity: 0;
      transform: translateY(-10px);
      pointer-events: none;
      transition: opacity .22s, transform .22s cubic-bezier(.25,.46,.45,.94);
    }

    .nav-mobile-menu.open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }

    .nav-mobile-links { list-style: none; }

    .nav-mobile-links li { border-bottom: 1px solid var(--border); }
    .nav-mobile-links li:last-child { border-bottom: none; }

    .nav-mobile-links a {
      display: block;
      font-family: 'Syne', sans-serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--muted);
      text-decoration: none;
      padding: 16px 0;
      letter-spacing: -.03em;
      transition: color .2s;
    }

    .nav-mobile-links a:hover,
    .nav-mobile-links a.active { color: var(--text); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      nav { padding: 0 20px; }
      nav:not(.nav-pill) .nav-links { display: none; }  /* pill nav 保留链接可见 */
      .nav-menu-btn { display: flex; }
      .section { padding: 72px 20px; }
      footer { padding: 32px 20px; }
    }

    /* pill nav 极小屏防溢出 */
    @media (max-width: 480px) {
      nav.nav-pill { max-width: calc(100vw - 32px); padding: 0 14px; }
      nav.nav-pill .nav-links { gap: 18px; }
    }
  </style>
</head>
<body>

  <nav id="main-nav" class={navPill ? 'nav-pill' : ''}>
    <a class="nav-logo" href="/">李灿轩</a>
    <ul class="nav-links">
      <li><a href="/" class={isActive('/') ? 'active' : ''}>首页</a></li>
      <li><a href="/resume" class={isActive('/resume') ? 'active' : ''}>简历</a></li>
      <li><a href="/projects" class={isActive('/projects') ? 'active' : ''}>项目</a></li>
      <li><a href="/articles" class={isActive('/articles') ? 'active' : ''}>文章</a></li>
      <li><a href="/contact" class={isActive('/contact') ? 'active' : ''}>联系</a></li>
    </ul>
    {!navPill && (
      <button class="nav-menu-btn" id="nav-menu-btn" aria-label="菜单">
        <span></span>
        <span></span>
        <span></span>
      </button>
    )}
  </nav>

  {!navPill && (
    <div class="nav-mobile-menu" id="nav-mobile-menu">
      <ul class="nav-mobile-links">
        <li><a href="/" class={isActive('/') ? 'active' : ''}>首页</a></li>
        <li><a href="/resume" class={isActive('/resume') ? 'active' : ''}>简历</a></li>
        <li><a href="/projects" class={isActive('/projects') ? 'active' : ''}>项目</a></li>
        <li><a href="/articles" class={isActive('/articles') ? 'active' : ''}>文章</a></li>
        <li><a href="/contact" class={isActive('/contact') ? 'active' : ''}>联系</a></li>
      </ul>
    </div>
  )}

  <slot />

  <footer>
    <div class="footer-left">
      <strong>李灿轩</strong>
      <span>·</span>
      <span>AI 产品经理</span>
      <span>·</span>
      <span>oridlcx@163.com</span>
    </div>
    <div class="footer-right">© 2026 · 求职意向：AI 产品经理</div>
  </footer>

  <!-- WeChat Modal -->
  <div class="modal-overlay" id="wechat-modal">
    <div class="modal-box">
      <div class="modal-wechat-icon">
        <svg viewBox="0 0 24 24"><path d="M9.5 7c.83 0 1.5.67 1.5 1.5S10.33 10 9.5 10 8 9.33 8 8.5 8.67 7 9.5 7zm5 0c.83 0 1.5.67 1.5 1.5S15.33 10 14.5 10 13 9.33 13 8.5 13.67 7 14.5 7zM12 2C6.48 2 2 6.03 2 11c0 2.7 1.28 5.12 3.31 6.79L4.5 21l3.64-1.82C9.33 19.71 10.63 20 12 20c5.52 0 10-4.03 10-9S17.52 2 12 2z"/></svg>
      </div>
      <div class="modal-title">添加微信</div>
      <div class="modal-sub">扫描下方二维码</div>
      <div class="qr-wrap">
        <img src="/wechat-qr.jpg" alt="微信二维码" />
      </div>
      <button class="modal-close" id="wechat-close">关闭</button>
    </div>
  </div>

  <script>
    // ── Scroll reveal ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ── Counter animation ──
    function animateCount(el: HTMLElement) {
      const target = parseInt(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      const duration = 1400;
      const start = performance.now();
      function update(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target).toLocaleString() + suffix;
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          animateCount(e.target as HTMLElement);
          counterObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

    // ── WeChat modal ──
    const modal = document.getElementById('wechat-modal')!;
    document.getElementById('wechat-close')?.addEventListener('click', () => modal.classList.remove('open'));
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('open'); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') modal.classList.remove('open'); });

    // ── Navbar：scrolled border + 上/下滚 collapse ──
    const nav = document.getElementById('main-nav')!;
    const isPill = nav.classList.contains('nav-pill');
    let lastScrollY = window.scrollY;
    const COLLAPSE_THRESHOLD = 90; // 滚超过此距离才开始 collapse

    function updateNavCollapse() {
      const y = window.scrollY;
      nav.classList.toggle('scrolled', y > 20);

      if (y < COLLAPSE_THRESHOLD) {
        // 顶部区域：强制展开
        nav.classList.remove('nav-collapsed');
      } else if (y > lastScrollY + 4) {
        // 向下滚：collapse（移动端 pill 不折叠，tap 区域太小）
        if (!(isPill && window.innerWidth <= 768)) {
          nav.classList.add('nav-collapsed');
        }
      } else if (y < lastScrollY - 2) {
        // 向上滚：expand
        nav.classList.remove('nav-collapsed');
      }
      lastScrollY = y;
    }

    window.addEventListener('scroll', updateNavCollapse, { passive: true });

    // 点击收缩态 pill 可直接展开
    if (isPill) {
      nav.addEventListener('click', () => {
        if (nav.classList.contains('nav-collapsed')) {
          nav.classList.remove('nav-collapsed');
        }
      });
    }

    // ── Hamburger menu ──
    const menuBtn = document.getElementById('nav-menu-btn');
    const mobileMenu = document.getElementById('nav-mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const open = menuBtn.classList.toggle('open');
        mobileMenu.classList.toggle('open', open);
      });
      mobileMenu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          menuBtn.classList.remove('open');
          mobileMenu.classList.remove('open');
        });
      });
    }
  </script>

</body>
</html>
