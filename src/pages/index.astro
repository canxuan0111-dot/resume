---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页" navPill={true}>
  <main>

    <!-- ── Hero ── -->
    <section id="hero">

      <!-- 背景图（视差层，JS 控制 translateY） -->
      <div class="hero-bg"></div>

      <!-- 遮罩：左侧 + 底部加深 -->
      <div class="hero-overlay"></div>

      <!-- 内容层（绝对坐标定位各元素） -->
      <div class="hero-content">

        <!-- 左上角：描述文字 + CTA -->
        <div class="hero-tl hero-a hero-a-tl">
          <p class="hero-desc">
            专注 AI 产品从 0 到 1 全链路落地，<br>
            End-to-end AI product, from 0 to 1.
          </p>
          <a class="hero-cta" href="/resume">
            <span class="cta-circle">→</span>
            查看简历
          </a>
        </div>

        <!-- 左下角：大字名字 -->
        <h1 class="hero-name hero-a hero-a-name">
          李灿轩<span class="hero-sep"> / </span>Louis
        </h1>

        <!-- 底部居中 tagline -->
        <p class="hero-tagline hero-a hero-a-tagline">AI 产品经理 · AI Product Manager</p>

        <!-- 滚动指示器（右下角） -->
        <div class="hero-scroll hero-a hero-a-scroll" aria-hidden="true">
          <div class="scroll-mouse">
            <div class="scroll-wheel"></div>
          </div>
          <div class="scroll-arrows">
            <span></span>
            <span></span>
          </div>
          <span class="scroll-label">SCROLL</span>
        </div>

      </div>
    </section>

    <!-- ── About ── -->
    <section id="about">
      <div class="section">
        <p class="about-quote">
          将科技和人文融入产品，从 0 到 1——<br>
          这是我 6 年来一直在做的事。
        </p>
        <div class="about-body">
          <!-- 左：照片卡片 -->
          <div class="about-photo-wrap">
            <div class="about-photo-card">
              <img src="/avatar.jpg" alt="Louis" class="about-photo" />
              <div class="about-photo-footer">
                <span class="about-photo-label">关于 Louis</span>
                <a class="about-photo-btn" href="/resume" aria-label="查看简历">↗</a>
              </div>
            </div>
          </div>
          <!-- 右：文字 -->
          <div class="about-text">
            <p class="about-since">Since 2018</p>
            <p class="about-desc">
              我是李灿轩，拥有 6 年产品经理从业经验。擅长将 AI 能力系统性融入产品设计与研发全流程，从用户需求拆解、AI 工具选型，到全链路产品落地。
            </p>
            <p class="about-desc">
              在不确定性中找到最优路径，让 AI 真正为业务创造价值——是我始终在做的事。
            </p>
            <a class="about-cta" href="/contact">
              <span class="cta-circle">→</span>
              联系我
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Selected Work ── -->
    <section id="selected-work">
      <div class="section">
        <div class="sw-header">
          <h2 class="sw-title">精选项目</h2>
          <p class="sw-subtitle">将 AI 与产品结合，从概念验证到完整上线，<br>每个项目都是从 0 到 1 的完整落地。</p>
        </div>
        <div class="sw-list">
          <a class="sw-item" href="/projects/ai-ad-assistant">
            <span class="sw-cat">AI SaaS · 小红书投放</span>
            <span class="sw-name-group">
              <span class="sw-name">AI 轻松投</span>
              <span class="sw-cover sw-cover-1"></span>
            </span>
            <span class="sw-year">2025</span>
          </a>
          <a class="sw-item" href="/projects/jd-promo">
            <span class="sw-cat">平台产品 · 游戏化机制</span>
            <span class="sw-name-group">
              <span class="sw-name">京东大促互动</span>
              <span class="sw-cover sw-cover-2"></span>
            </span>
            <span class="sw-year">2022</span>
          </a>
          <a class="sw-item" href="/projects/personal-website">
            <span class="sw-cat">产品设计 · Vibe Coding</span>
            <span class="sw-name-group">
              <span class="sw-name">个人网站</span>
              <span class="sw-cover sw-cover-3"></span>
            </span>
            <span class="sw-year">2025</span>
          </a>
          <a class="sw-item" href="/projects/agent-architecture">
            <span class="sw-cat">AI 工程 · 架构设计</span>
            <span class="sw-name-group">
              <span class="sw-name" style="white-space: nowrap;">Agent 架构研究</span>
              <span class="sw-cover sw-cover-4"></span>
            </span>
            <span class="sw-year">2026</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Why Choose Me ── -->
    <section id="why-me">
      <div class="section">
        <h2 class="wm-title reveal">为什么选择我</h2>
        <div class="wm-body">
          <!-- 左：卡片 -->
          <div class="wm-card reveal reveal-delay-1">
            <img src="/front.jpg" alt="Louis" class="wm-avatar" />
            <h3 class="wm-card-heading">需要 AI 产品经理？</h3>
            <p class="wm-card-desc">帮助团队将 AI 能力系统性落地，从需求定义、工具选型，到全链路交付，以结构化方法推动清晰结果。</p>
            <a class="wm-cta" href="/resume">
              <span class="cta-circle">→</span>
              查看简历
            </a>
          </div>
          <!-- 右：说明 + 标签 -->
          <div class="wm-right reveal reveal-delay-2">
            <p class="wm-label">我能做什么</p>
            <p class="wm-desc">
              无论是构建 AI 驱动的产品体验、设计多 Agent 架构，还是将复杂的 AI 能力融入用户友好的界面——我的工作核心是将愿景转化为可落地的结果。每个项目都针对具体问题量身定制，以产品思维驱动 AI 能力选型，创造可量化的长期业务价值。
            </p>
            <div class="wm-tags">
              <span class="wm-tag">AI 产品设计</span>
              <span class="wm-tag">需求分析与定义</span>
              <span class="wm-tag">AI 工具选型</span>
              <span class="wm-tag">用户体验设计</span>
              <span class="wm-tag">全链路落地</span>
              <span class="wm-tag">数据驱动优化</span>
              <span class="wm-tag">Vibe Coding</span>
              <span class="wm-tag">快速原型验证</span>
              <span class="wm-tag">Agent 架构设计</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 装饰图 ── -->
    <section id="deco-img">
      <img src="/楼层装饰图.jpg" alt="" class="deco-full-img" />
    </section>

    <!-- ── My Process ── -->
    <section id="process">
      <div class="section">
        <h2 class="proc-title">我的工作方法</h2>
        <p class="proc-lead">
          从发现问题到完整交付，我遵循一套经过验证的方法路径——以深度研究为起点，经过快速迭代验证，以数据驱动的持续优化为终点。每个 AI 产品都不只是功能的堆砌；它们讲述用户故事，建立真实连接，并为业务创造可量化的长期价值。
        </p>
        <div class="proc-cols">
          <div class="proc-col">
            <span class="proc-num">01</span>
            <div class="proc-col-bottom">
              <h3 class="proc-col-title"><span class="proc-dot"></span>发现 & 定义</h3>
              <p class="proc-col-desc">深入理解问题本质，拆解用户需求与业务目标，建立清晰的成功指标。在这个阶段，「问对问题」比「给出答案」更重要。</p>
            </div>
          </div>
          <div class="proc-col">
            <span class="proc-num">02</span>
            <div class="proc-col-bottom">
              <h3 class="proc-col-title"><span class="proc-dot"></span>设计 & 验证</h3>
              <p class="proc-col-desc">AI 工具选型、产品原型搭建、与技术团队深度协作。通过快速迭代和小规模验证，在资源投入最小的阶段找到最优路径。</p>
            </div>
          </div>
          <div class="proc-col">
            <span class="proc-num">03</span>
            <div class="proc-col-bottom">
              <h3 class="proc-col-title"><span class="proc-dot"></span>落地 & 优化</h3>
              <p class="proc-col-desc">全链路上线监控，以数据为驱动持续迭代。每次项目结束后沉淀可复用的方法论，让下一次交付质量更高、周期更短。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Latest Insights ── -->
    <section id="insights">
      <div class="section">
        <div class="ins-header">
          <h2 class="ins-title">最新思考</h2>
          <a class="ins-view-all" href="/articles">
            <span class="cta-circle-sm">→</span>
            查看全部文章
          </a>
        </div>
        <p class="ins-sub">探索 AI 产品设计、架构决策与方法论，分享来自一线实践的经验。</p>
        <div class="ins-grid">
          <a class="ins-card" href="/articles/agent-architecture">
            <div class="ins-cover ins-cover-1"></div>
            <div class="ins-card-body">
              <div class="ins-card-meta">2026-03 · 15 min read</div>
              <div class="ins-card-title">Agent 产品架构工程化深度落地指南</div>
              <div class="ins-card-arrow">↗</div>
            </div>
          </a>
          <a class="ins-card" href="/articles/openclaw-vs-react">
            <div class="ins-cover ins-cover-2"></div>
            <div class="ins-card-body">
              <div class="ins-card-meta">2026-01 · 10 min read</div>
              <div class="ins-card-title">OpenClaw vs ReAct vs 多 Agent 编排</div>
              <div class="ins-card-arrow">↗</div>
            </div>
          </a>
          <a class="ins-card" href="/articles/agent-intro">
            <div class="ins-cover ins-cover-3"></div>
            <div class="ins-card-body">
              <div class="ins-card-meta">2025-12 · 5 min read</div>
              <div class="ins-card-title">Agent 入门：新变化与新认知</div>
              <div class="ins-card-arrow">↗</div>
            </div>
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ── Hero 容器 ── */
  #hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 620px;
    overflow: hidden;
  }

  /* ── 背景图（视差：顶部多出 15%，JS translateY） ── */
  .hero-bg {
    position: absolute;
    top: -15%;
    left: 0; right: 0;
    height: 130%;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: center 20%;
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,  rgba(0,0,0,0.52) 0%, rgba(0,0,0,0.18) 45%, rgba(0,0,0,0) 100%),
      linear-gradient(to top,    rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.12) 40%, rgba(0,0,0,0) 70%);
  }

  .hero-content {
    position: absolute;
    inset: 0;
  }

  /* ══ 入场动画 keyframes ══ */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* 基础类：fill-mode both = 动画前保持 from 状态 */
  .hero-a {
    animation-fill-mode: both;
    animation-timing-function: cubic-bezier(0.22, 0.8, 0.44, 1);
    animation-duration: 0.8s;
  }

  .hero-a-tl     { animation-name: heroFadeUp;  animation-delay: 0.05s; }
  .hero-a-name   { animation-name: heroFadeUp;  animation-delay: 0.2s;  }
  .hero-a-tagline{ animation-name: heroFadeIn;  animation-delay: 0.45s; }
  .hero-a-scroll { animation-name: heroFadeIn;  animation-delay: 0.75s; }

  /* ── 左上角文案区 ── */
  .hero-tl {
    position: absolute;
    top: 88px;
    left: 40px;
    will-change: transform;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 240px;
  }

  .hero-desc {
    font-size: 13.5px;
    color: rgba(255,255,255,0.75);
    line-height: 1.8;
    letter-spacing: .05px;
  }

  /* ── CTA 按钮 ── */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #0a0a0a;
    padding: 6px 20px 6px 6px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    width: fit-content;
    transition: background .25s, transform .25s;
  }

  .hero-cta:hover {
    background: #fff;
    transform: translateY(-2px);
  }

  .cta-circle {
    width: 36px;
    height: 36px;
    background: #f9442c;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: #fff;
    flex-shrink: 0;
    line-height: 1;
    transition: transform .3s cubic-bezier(0.34,1.56,0.64,1);
  }

  .hero-cta:hover .cta-circle {
    transform: rotate(45deg) scale(1.08);
  }

  /* ── 大字名字（左下） ── */
  .hero-name {
    position: absolute;
    bottom: 60px;
    left: 28px;
    will-change: transform;
    font-family: 'Syne', sans-serif;
    font-size: clamp(64px, 14vw, 200px);
    font-weight: 400;
    letter-spacing: -.04em;
    line-height: .9;
    color: #fff;
    margin: 0;
  }

  .hero-sep {
    color: rgba(255,255,255,0.35);
  }

  /* ── 底部居中 tagline ── */
  .hero-tagline {
    position: absolute;
    bottom: 20px;
    will-change: transform;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* ══ 滚动指示器（右下角）鼠标图标版 ══ */
  .hero-scroll {
    position: absolute;
    right: 36px;
    bottom: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    will-change: transform;
  }

  /* 鼠标外框 */
  .scroll-mouse {
    width: 24px;
    height: 38px;
    border: 2px solid rgba(255,255,255,0.75);
    border-radius: 12px;
    position: relative;
    display: flex;
    justify-content: center;
    box-shadow: 0 0 12px rgba(255,255,255,0.15);
  }

  /* 滚轮小点 */
  .scroll-wheel {
    width: 4px;
    height: 7px;
    background: #fff;
    border-radius: 2px;
    position: absolute;
    top: 6px;
    animation: wheelBounce 1.6s cubic-bezier(.45,0,.55,1) infinite;
  }

  @keyframes wheelBounce {
    0%   { top: 6px;  opacity: 1; }
    60%  { top: 18px; opacity: 0.2; }
    100% { top: 6px;  opacity: 1; }
  }

  /* 双箭头 */
  .scroll-arrows {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .scroll-arrows span {
    display: block;
    width: 10px;
    height: 10px;
    border-right: 2px solid rgba(255,255,255,0.75);
    border-bottom: 2px solid rgba(255,255,255,0.75);
    transform: rotate(45deg);
    animation: arrowFade 1.6s ease-in-out infinite;
  }

  .scroll-arrows span:nth-child(2) {
    animation-delay: .18s;
    opacity: 0.5;
  }

  @keyframes arrowFade {
    0%, 100% { opacity: 0.2; transform: rotate(45deg) translateY(-3px); }
    50%       { opacity: 1;   transform: rotate(45deg) translateY(2px);  }
  }

  /* SCROLL 文字 */
  .scroll-label {
    font-size: 10px;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.6);
    font-weight: 600;
    text-transform: uppercase;
  }

  /* ════════════════════════════════
     About 楼层
  ════════════════════════════════ */
  #about {
    background: var(--bg);
    padding: 100px 0 110px;
  }

  /* 大号引言 */
  .about-quote {
    font-family: 'Syne', sans-serif;
    font-size: clamp(26px, 3.6vw, 48px);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -.03em;
    color: var(--text);
    text-align: center;
    max-width: 760px;
    margin: 0 auto 72px;
  }

  /* 下方主体：左图右文 */
  .about-body {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 60px;
    align-items: start;
  }

  /* 照片卡片 */
  .about-photo-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #111;
    position: relative;
  }

  .about-photo {
    display: block;
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    object-position: center top;
  }

  .about-photo-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(8px);
  }

  .about-photo-label {
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
    letter-spacing: .4px;
  }

  .about-photo-btn {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 14px;
    text-decoration: none;
    transition: background .2s, transform .25s;
  }

  .about-photo-btn:hover {
    background: rgba(255,255,255,0.28);
    transform: scale(1.1);
  }

  /* 右侧文字 */
  .about-text {
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-since {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .about-desc {
    font-size: 16px;
    line-height: 1.8;
    color: rgba(10,10,10,0.72);
  }

  /* CTA 按钮（复用 hero 样式） */
  .about-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--text);
    color: #fff;
    padding: 6px 22px 6px 6px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    width: fit-content;
    margin-top: 8px;
    transition: opacity .2s, transform .25s;
  }

  .about-cta:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .about-cta .cta-circle {
    width: 36px;
    height: 36px;
    background: #f9442c;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: #fff;
    flex-shrink: 0;
    transition: transform .3s cubic-bezier(0.34,1.56,0.64,1);
  }

  .about-cta:hover .cta-circle {
    transform: rotate(45deg) scale(1.08);
  }

  /* ════════════════════════════════
     Selected Work 楼层
  ════════════════════════════════ */
  #selected-work {
    background: var(--bg-alt);
    padding: 100px 0 80px;
  }

  .sw-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 56px;
  }

  .sw-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 400;
    letter-spacing: -.04em;
    color: var(--text);
    margin: 0;
    flex-shrink: 0;
  }

  .sw-subtitle {
    font-size: 14px;
    line-height: 1.7;
    color: var(--muted);
    max-width: 320px;
    text-align: right;
    padding-top: 8px;
  }

  /* 列表 */
  .sw-list {
    border-top: 1px solid var(--border);
  }

  .sw-item {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background .2s;
    border-radius: 0;
    position: relative;
  }

  .sw-item::before {
    content: '';
    position: absolute;
    inset: 0 -40px;
    background: #0a0a0a;
    border-radius: 0;
    opacity: 0;
    transition: opacity .28s cubic-bezier(.25,.46,.45,.94);
    z-index: 0;
  }

  .sw-item:hover::before { opacity: 1; }

  .sw-item > * { position: relative; z-index: 1; }

  .sw-cat {
    font-size: 12px;
