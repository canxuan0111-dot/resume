<script>
  // ── 胶囊 nav 在 hero 上保持白色 ──
  const nav = document.getElementById('main-nav')!;
  const hero = document.getElementById('hero')!;

  function updateNav() {
    nav.classList.toggle('nav-hero', hero.getBoundingClientRect().bottom > 60);
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // ── 多层视差：背景 / 小字 / 大字 三层不同速度 ──
  const heroBg       = document.querySelector('.hero-bg')      as HTMLElement;
  const heroTl       = document.querySelector('.hero-tl')      as HTMLElement;
  const heroName     = document.querySelector('.hero-name')    as HTMLElement;
  const heroTagline  = document.querySelector('.hero-tagline') as HTMLElement;
  const heroScroll   = document.querySelector('.hero-scroll')  as HTMLElement;

  // 预设各层速率（正值 = 向下偏移更慢，即留在视野更长；负值 = 向上额外偏移更快）
  // 背景 +0.30：最慢，下沉感
  // 小字 -0.08：略快于自然滚动，轻飘感
  // 大字 -0.22：最快出屏，强烈前景感
  let rafId = 0;

  function updateParallax() {
    rafId = 0;
    const s = window.scrollY;
    if (s > hero.offsetHeight) return;

    heroBg.style.transform      = `translateY(${s * 0.30}px)`;
    heroTl.style.transform      = `translateY(${s * -0.08}px)`;
    heroName.style.transform    = `translateY(${s * -0.22}px)`;
    heroTagline.style.transform = `translateY(${s * -0.12}px)`;
    if (heroScroll) heroScroll.style.transform = `translateY(${s * -0.15}px)`;
  }

  window.addEventListener('scroll', () => {
    if (!rafId) rafId = requestAnimationFrame(updateParallax);
  }, { passive: true });

  // ── 装饰图：滚入时缩放动效 ──
  const decoSection = document.getElementById('deco-img');
  if (decoSection) {
    const decoObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          decoSection.classList.add('deco-visible');
          decoObs.unobserve(decoSection);
        }
      });
    }, { threshold: 0.1 });
    decoObs.observe(decoSection);
  }
</script>
