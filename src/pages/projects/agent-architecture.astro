---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Tag from '../../components/Tag.astro';
import CtaButton from '../../components/CtaButton.astro';

const CODE_FLOW_STEPS = `FLOW_STEPS = {
  generate_copy: [
    'sku_select',           // 卡片：选择 SKU
    'template_select',      // 卡片：选择文案模板
    'agent_generate_copy',  // Agent：调用 generate_copy 工具
  ],
  image_from_new_copy: [
    'sku_select',
    'template_select',
    'agent_generate_copy',
    'copy_version_select',      // 卡片：选择文案版本
    'image_template_select',    // 卡片：选择图片模板（可跳过）
    'agent_generate_image',     // Agent：调用 generate_images 工具
  ],
  image_from_existing: [
    'copy_version_select',
    'image_template_select',
    'agent_generate_image',
  ],
  image_direct: [
    'sku_select',
    'image_template_select',
    'agent_generate_image',
  ],
}`;

const CODE_BUG2_PAGE = `setMessages((prev) =>
  prev.map((m) =>
    m.id === assistantMessage.id
      ? { ...m, metadata: { ...genData, hide_image_gen_button: true } }
      : m,
  ),
);`;

const CODE_BUG2_MSG = `onImageGen={data?.hide_image_gen_button ? undefined : onImageGen}`;

const CODE_GENERATE_COPY = `// 直接调用工具，绕过 Agent 的意图识别层
export async function POST(req: Request) {
  const { skuId, templateId } = await req.json();
  return executeTool('generate_copy', { skuId, templateId });
}`;

const CODE_GUIDANCE_MAP = `const TOOL_GUIDANCE_MAP = {
  generated_content: '选好版本后，点击「生成配图」可继续制作图片素材。',
  diagnosis_card:    '诊断完成！可以说「帮我生成优化方案」继续查看推荐方案。',
  daily_summary:     '可以继续查看诊断分析，或告诉我想调整的方向。',
  // ...
};

// 工具执行完成后，若返回卡片类型则提前返回，跳过第 3 次 LLM 调用
if (lastToolResult.message_type !== 'chat') {
  return assemblePayload(lastToolResult, TOOL_GUIDANCE_MAP);
}`;

const CODE_ELAPSED = `function useElapsedSeconds() {
  const [elapsed, setElapsed] = useState(0);
  useEffect(() => {
    const t = setInterval(() => setElapsed((s) => s + 1), 1000);
    return () => clearInterval(t);
  }, []);
  return elapsed;
}`;
---

<Layout title="Agent 架构研究 · FlowEngine" navPill={true}>
  <main class="pd">

    <!-- ① Hero -->
    <section class="pd-hero">
      <img src="/Agent-Hero.jpg" alt="" class="pd-hero-bg-img" aria-hidden="true" />
      <div class="pd-hero-overlay"></div>
      <div class="pd-hero-content">
        <div class="pd-hero-bl pd-ha pd-ha-bl">
          <div class="pd-hero-tags">
            <Tag label="AI 工程" variant="hero" />
            <Tag label="2026.03" variant="hero" />
            <Tag label="架构设计 · 状态机 · 性能优化" variant="hero" />
          </div>
          <h1 class="pd-hero-title">FlowEngine<br>架构研究</h1>
          <p class="pd-hero-sub">从 LLM 状态依赖到确定性状态机<br>AI 对话流程编排的架构迁移与性能调优</p>
          <div class="pd-hero-rule"></div>
          <div class="pd-hero-stats">
            <div class="pd-stat"><div class="pd-stat-val">−67%</div><div class="pd-stat-lbl">文案生成耗时</div></div>
            <div class="pd-stat"><div class="pd-stat-val">3 → 1</div><div class="pd-stat-lbl">LLM 调用次数</div></div>
            <div class="pd-stat"><div class="pd-stat-val">4 Bugs</div><div class="pd-stat-lbl">架构重构后归零</div></div>
            <div class="pd-stat"><div class="pd-stat-val">3 层</div><div class="pd-stat-lbl">分治架构</div></div>
          </div>
        </div>
        <div class="pd-hero-scroll pd-ha pd-ha-scroll" aria-hidden="true">
          <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
          <div class="scroll-arrows"><span></span><span></span></div>
          <span class="scroll-label">SCROLL</span>
        </div>
      </div>
    </section>

    <!-- ② 问题背景 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="问题背景"
          title="4 个 Bug，<br>1 个架构级矛盾。"
        />
        <p class="arch-lead reveal reveal-delay-2">
          在"对话卡片化"重构上线后，配图生成流程出现了 4 个 Bug。表面看是 4 个独立问题，但深层只有 1 个根因。
        </p>

        <div class="arch-table-wrap reveal reveal-delay-3">
          <table class="arch-table">
            <thead>
              <tr>
                <th>Bug</th>
                <th>场景</th>
                <th>现象</th>
                <th>根因</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="arch-td-num">01</td>
                <td>选择"重新生成文案，再生成配图"</td>
                <td>SKU 卡片中有图片的商品显示占位符</td>
                <td>构造 <code>sku_select_card</code> 时使用了不存在的 <code>image_url</code> 字段，而不是 <code>images</code> 数组</td>
              </tr>
              <tr>
                <td class="arch-td-num">02</td>
                <td>文案生成完成后</td>
                <td>文案结果卡片有"生成配图"按钮，与下方选择卡功能重叠</td>
                <td>复用了独立文案生成的结果卡片，该卡片默认带配图按钮</td>
              </tr>
              <tr class="arch-tr-critical">
                <td class="arch-td-num">03</td>
                <td>选择文案版本后</td>
                <td>没有弹出图片模板选择卡，而是回复了一句无关文字</td>
                <td><code>handleCopyVersionSelect</code> 把消息发给 Agent，Agent 无法从上下文可靠推断下一步应调用哪个工具</td>
              </tr>
              <tr class="arch-tr-critical">
                <td class="arch-td-num">04</td>
                <td>Bug 3 后用户手动输入</td>
                <td>系统回复了投放报告卡片</td>
                <td>Agent 完全误判意图——Bug 3 的直接后果</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="arch-insight reveal reveal-delay-4">
          <div class="arch-insight-icon">!</div>
          <div>
            <div class="arch-insight-label">深层根因</div>
            <p>Bug 3 和 Bug 4 不是个别 Bug，而是<strong>架构级问题</strong>——LLM 天然不擅长维护有序状态。当固定流程的步骤推进依赖 Agent 从对话历史推断「当前处于第几步」时，步骤数越多，出错概率越高。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ 架构方案 -->
    <section class="pd-section pd-alt">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="架构方案"
          title="FlowEngine，<br>三层分治。"
        />

        <div class="arch-layers reveal reveal-delay-2">
          <div class="arch-layer arch-layer--1">
            <div class="arch-layer-top">
              <div class="arch-layer-badge">第一层</div>
              <div class="arch-layer-file">lib/flow-engine.ts</div>
            </div>
            <div class="arch-layer-name">Workflow Controller</div>
            <p class="arch-layer-desc">确定性状态机，硬编码步骤顺序，<strong>完全不经过 LLM</strong></p>
          </div>
          <div class="arch-layer-conn">
            <div class="arch-layer-conn-line"></div>
            <div class="arch-layer-conn-dot"></div>
          </div>
          <div class="arch-layer arch-layer--2">
            <div class="arch-layer-top">
              <div class="arch-layer-badge">第二层</div>
              <div class="arch-layer-file">chat/route.ts</div>
            </div>
            <div class="arch-layer-name">Agent Guide</div>
            <p class="arch-layer-desc">只在 agent 节点工作，负责内容生成（generate_copy 等）</p>
          </div>
          <div class="arch-layer-conn">
            <div class="arch-layer-conn-line"></div>
            <div class="arch-layer-conn-dot"></div>
          </div>
          <div class="arch-layer arch-layer--3">
            <div class="arch-layer-top">
              <div class="arch-layer-badge">第三层</div>
              <div class="arch-layer-file">FlowContext</div>
            </div>
            <div class="arch-layer-name">Shared Task Context</div>
            <p class="arch-layer-desc">跨步骤数据共享（选中的 SKU、模板、文案版本等）</p>
          </div>
        </div>

        <div class="arch-resp reveal reveal-delay-3">
          <div class="arch-resp-eyebrow">职责边界</div>
          <div class="arch-resp-grid">
            <div class="arch-resp-col">
              <div class="arch-resp-title">FlowEngine</div>
              <div class="arch-resp-items">
                <div class="arch-resp-item arch-resp-item--do">✓ 定义步骤顺序</div>
                <div class="arch-resp-item arch-resp-item--do">✓ 推进步骤</div>
                <div class="arch-resp-item arch-resp-item--do">✓ 管理上下文</div>
                <div class="arch-resp-item arch-resp-item--dont">✗ 不生成内容</div>
                <div class="arch-resp-item arch-resp-item--dont">✗ 不调用 API</div>
              </div>
            </div>
            <div class="arch-resp-divider"></div>
            <div class="arch-resp-col">
              <div class="arch-resp-title">Agent</div>
              <div class="arch-resp-items">
                <div class="arch-resp-item arch-resp-item--do">✓ 识别开放对话意图</div>
                <div class="arch-resp-item arch-resp-item--do">✓ 在 agent 节点执行工具</div>
                <div class="arch-resp-item arch-resp-item--dont">✗ 不推进流程步骤</div>
                <div class="arch-resp-item arch-resp-item--dont">✗ 不维护流程状态</div>
              </div>
            </div>
            <div class="arch-resp-divider"></div>
            <div class="arch-resp-col">
              <div class="arch-resp-title">page.tsx</div>
              <div class="arch-resp-items">
                <div class="arch-resp-item arch-resp-item--do">✓ 执行 FlowEngine 返回的步骤指令</div>
                <div class="arch-resp-item arch-resp-item--do">✓ 注入卡片 / 调用 Agent</div>
                <div class="arch-resp-item arch-resp-item--dont">✗ 不硬编码流程顺序</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 流程定义 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="流程定义"
          title="4 个固定流程，<br>声明式步骤表。"
        />

        <div class="arch-code-block reveal reveal-delay-2">
          <div class="arch-code-header">
            <div class="arch-code-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="arch-code-filename">lib/flow-engine.ts</span>
            <span class="arch-code-lang">TypeScript</span>
          </div>
          <pre class="arch-code"><code set:text={CODE_FLOW_STEPS} /></pre>
        </div>

        <div class="arch-flows reveal reveal-delay-3">
          <div class="arch-flow">
            <div class="arch-flow-name">generate_copy</div>
            <div class="arch-flow-steps">
              <div class="arch-step arch-step--card">sku_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--card">template_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--agent">agent_generate_copy</div>
            </div>
          </div>
          <div class="arch-flow">
            <div class="arch-flow-name">image_from_new_copy</div>
            <div class="arch-flow-steps">
              <div class="arch-step arch-step--card">sku_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--card">template_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--agent">agent_generate_copy</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--card">copy_version_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--card">image_template_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--agent">agent_generate_image</div>
            </div>
          </div>
          <div class="arch-flow">
            <div class="arch-flow-name">image_from_existing</div>
            <div class="arch-flow-steps">
              <div class="arch-step arch-step--card">copy_version_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--card">image_template_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--agent">agent_generate_image</div>
            </div>
          </div>
          <div class="arch-flow">
            <div class="arch-flow-name">image_direct</div>
            <div class="arch-flow-steps">
              <div class="arch-step arch-step--card">sku_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--card">image_template_select</div>
              <div class="arch-step-arrow">→</div>
              <div class="arch-step arch-step--agent">agent_generate_image</div>
            </div>
          </div>
        </div>

        <div class="arch-step-legend reveal reveal-delay-4">
          <div class="arch-legend-item">
            <div class="arch-step arch-step--card arch-step--sm">card 步骤</div>
            <p>客户端从本地数据构造卡片，直接注入消息列表，不调用 LLM</p>
          </div>
          <div class="arch-legend-item">
            <div class="arch-step arch-step--agent arch-step--sm">agent 步骤</div>
            <p>客户端发送消息给 Agent，Agent 调用工具生成内容</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ Bug 修复对照 -->
    <section class="pd-section pd-alt">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="Bug 修复"
          title="每个 Bug，<br>架构层面的解法。"
        />

        <div class="arch-bugfixes">

          <!-- Bug 01 -->
          <div class="arch-bugfix reveal reveal-delay-2">
            <div class="arch-bugfix-head">
              <span class="arch-bugfix-num">Bug 01</span>
              <span class="arch-bugfix-title">SKU 图片字段名错误</span>
            </div>
            <div class="arch-bugfix-body">
              <div class="arch-code-block">
                <div class="arch-code-header">
                  <div class="arch-code-dots"><span></span><span></span><span></span></div>
                  <span class="arch-code-filename">构造 sku_select_card</span>
                  <span class="arch-code-lang">Diff</span>
                </div>
                <pre class="arch-code arch-code--diff"><code><span class="code-del">- image_url: s.image_url ?? null,   // SkuRow 没有 image_url 字段</span>
<span class="code-add">+ promotion_info: s.promotion_info ?? null,</span>
<span class="code-add">+ images: s.images ?? null,          // 使用正确的 images 字段</span></code></pre>
              </div>
            </div>
          </div>

          <!-- Bug 02 -->
          <div class="arch-bugfix reveal reveal-delay-2">
            <div class="arch-bugfix-head">
              <span class="arch-bugfix-num">Bug 02</span>
              <span class="arch-bugfix-title">配图按钮与文案选择卡功能重叠</span>
            </div>
            <div class="arch-bugfix-body">
              <p class="arch-bugfix-desc">当流程在 <code>agent_generate_copy</code> 步骤完成时，给 <code>generated_content</code> 消息加上 <code>hide_image_gen_button: true</code> 标记，<code>ChatMessage.tsx</code> 据此隐藏按钮。</p>
              <div class="arch-code-grid">
                <div class="arch-code-block">
                  <div class="arch-code-header">
                    <div class="arch-code-dots"><span></span><span></span><span></span></div>
                    <span class="arch-code-filename">page.tsx</span>
                    <span class="arch-code-lang">TypeScript</span>
                  </div>
                  <pre class="arch-code"><code set:text={CODE_BUG2_PAGE} /></pre>
                </div>
                <div class="arch-code-block">
                  <div class="arch-code-header">
                    <div class="arch-code-dots"><span></span><span></span><span></span></div>
                    <span class="arch-code-filename">ChatMessage.tsx</span>
                    <span class="arch-code-lang">TypeScript</span>
                  </div>
                  <pre class="arch-code"><code set:text={CODE_BUG2_MSG} /></pre>
                </div>
              </div>
            </div>
          </div>

          <!-- Bug 03 & 04 -->
          <div class="arch-bugfix arch-bugfix--critical reveal reveal-delay-3">
            <div class="arch-bugfix-head">
              <span class="arch-bugfix-num">Bug 03 & 04</span>
              <span class="arch-bugfix-title">选择文案版本后流程完全断裂（架构级）</span>
            </div>
            <div class="arch-bugfix-body">
              <div class="arch-evolution">
                <div class="arch-evo-step arch-evo-step--bad">
                  <div class="arch-evo-label">旧行为</div>
                  <p><code>handleCopyVersionSelect</code> → 把消息发给 Agent → Agent 需从对话历史推断「应调用什么工具」→ 推断失败，回复无关内容</p>
                </div>
                <div class="arch-evo-arrow">→</div>
                <div class="arch-evo-step arch-evo-step--good">
                  <div class="arch-evo-label">FlowEngine 解法</div>
                  <p>检测到 <code>isInFlow</code> → 调用 <code>advance()</code> → FlowEngine 自动推进到 <code>image_template_select</code> → 注入卡片。<strong>不再依赖 Agent 推断下一步。</strong></p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ⑥ 设计决策 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="设计决策"
          title="为什么这样设计，<br>而不是那样。"
        />

        <div class="arch-decisions">

          <div class="arch-decision reveal reveal-delay-2">
            <div class="arch-decision-q">为什么选择客户端状态机，而非服务端编排？</div>
            <div class="arch-decision-reasons">
              <div class="arch-reason">
                <span class="arch-reason-num">01</span>
                <span>所有固定流程都是单用户单会话内的，不需要持久化</span>
              </div>
              <div class="arch-reason">
                <span class="arch-reason-num">02</span>
                <span>步骤间的数据传递（SKU → 模板 → 文案版本）只在前端 UI 上有意义</span>
              </div>
              <div class="arch-reason">
                <span class="arch-reason-num">03</span>
                <span>客户端执行延迟更低，无需网络往返</span>
              </div>
            </div>
          </div>

          <div class="arch-decision reveal reveal-delay-3">
            <div class="arch-decision-q">为什么 <code>advance()</code> 返回步骤信息而非自动执行？</div>
            <div class="arch-decision-reasons">
              <div class="arch-reason">
                <span class="arch-reason-num">01</span>
                <span><code>advance()</code> 是纯状态变更函数，<code>executeStep()</code> 是有副作用的执行函数。分离两者，让调用方决定执行时机（如加 <code>setTimeout</code> 控制卡片出现节奏）</span>
              </div>
              <div class="arch-reason">
                <span class="arch-reason-num">02</span>
                <span>避免 hook 内部依赖 <code>setMessages</code>、<code>sendMessage</code> 等外部状态，保持 hook 纯净可测</span>
              </div>
              <div class="arch-reason">
                <span class="arch-reason-num">03</span>
                <span>状态变更和副作用的边界清晰，错误来源更易定位</span>
              </div>
            </div>
          </div>

          <div class="arch-decision reveal reveal-delay-4">
            <div class="arch-decision-q">哪些功能不纳入 FlowEngine？</div>
            <div class="arch-excl-table">
              <div class="arch-excl-row">
                <div class="arch-excl-feat">SKU / 模板 / 效果回填录入</div>
                <div class="arch-excl-reason">单步触发（Agent 识别 → 弹表单 → 提交），无多步依赖</div>
              </div>
              <div class="arch-excl-row">
                <div class="arch-excl-feat">看投放报告 / 优化方案</div>
                <div class="arch-excl-reason">开放对话（Agent 调一个工具返回一张卡），无固定步骤</div>
              </div>
              <div class="arch-excl-row">
                <div class="arch-excl-feat">护栏配置</div>
                <div class="arch-excl-reason">Agent 主导的多轮对话，步骤不固定</div>
              </div>
            </div>
            <div class="arch-decision-rule">
              <div class="arch-decision-rule-label">判断准则</div>
              <p>只有「步骤顺序固定、步骤间有数据依赖」的流程才纳入 FlowEngine。开放对话和单步任务交由 Agent 处理。</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ⑦ 性能优化 -->
    <section class="pd-section pd-alt">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="性能优化"
          title="3 次 LLM，<br>变成 1 次。"
        />
        <p class="arch-lead reveal reveal-delay-2">
          架构重构稳定后，发现另一个问题：文案生成需要 3 次串行 LLM 调用，总耗时 15–20 秒，而等待期间只有一个静态的「AI 正在处理」动效，用户完全是黑盒。
        </p>

        <div class="arch-chain reveal reveal-delay-2">
