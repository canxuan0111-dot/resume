---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI 轻松投">
  <main class="pd">

    <!-- ① Hero -->
    <section class="pd-hero">
      <div class="pd-hero-inner">
        <div class="pd-hero-tags">
          <span class="pd-htag">AI 产品经理</span>
          <span class="pd-htag">2024.06 – 2025.11</span>
          <span class="pd-htag">Multi-Agent · RAG · 多模态</span>
        </div>
        <h1 class="pd-hero-title">AI 轻松投</h1>
        <p class="pd-hero-sub">小红书电商腰部商家的<br>AI 投放全流程助手</p>
        <div class="pd-hero-metrics">
          <div class="pd-hm"><div class="pd-hm-val">3×</div><div class="pd-hm-lbl">效率提升</div></div>
          <div class="pd-hm-div"></div>
          <div class="pd-hm"><div class="pd-hm-val">98.6%</div><div class="pd-hm-lbl">素材准确率</div></div>
          <div class="pd-hm-div"></div>
          <div class="pd-hm"><div class="pd-hm-val">252万</div><div class="pd-hm-lbl">年收入</div></div>
          <div class="pd-hm-div"></div>
          <div class="pd-hm"><div class="pd-hm-val">20家</div><div class="pd-hm-lbl">付费客户</div></div>
          <div class="pd-hm-div"></div>
          <div class="pd-hm"><div class="pd-hm-val">85%+</div><div class="pd-hm-lbl">客户留存</div></div>
          <div class="pd-hm-div"></div>
          <div class="pd-hm"><div class="pd-hm-val">-95%</div><div class="pd-hm-lbl">模型成本</div></div>
        </div>
      </div>
    </section>

    <!-- ② 背景与问题 -->
    <section class="pd-section">
      <div class="section-inner">
        <p class="section-label reveal">背景与问题</p>
        <h2 class="section-headline reveal reveal-delay-1">谁在用，<br>为什么需要它？</h2>
        <div class="pd-problem-grid reveal reveal-delay-2">
          <div class="pd-user-card">
            <div class="pd-user-icon">👤</div>
            <div class="pd-user-title">目标用户</div>
            <div class="pd-user-desc">小红书电商腰部商家<br>年销 500万 – 5000万</div>
            <div class="pd-market">
              <div class="pd-market-item">
                <div class="pd-market-val">150–200亿</div>
                <div class="pd-market-lbl">GMV/年·市场规模</div>
              </div>
              <div class="pd-market-item">
                <div class="pd-market-val">20–50亿</div>
                <div class="pd-market-lbl">服务市场空间</div>
              </div>
            </div>
          </div>
          <div class="pd-pains">
            <div class="pd-pain">
              <div class="pd-pain-num">01</div>
              <div class="pd-pain-body">
                <div class="pd-pain-title">内容生产低效</div>
                <p class="pd-pain-desc">一条合格素材需策划、设计、文案多轮协作，周产出仅 50 条，无法覆盖投放消耗。</p>
              </div>
            </div>
            <div class="pd-pain">
              <div class="pd-pain-num">02</div>
              <div class="pd-pain-body">
                <div class="pd-pain-title">投放决策碎片化</div>
                <p class="pd-pain-desc">预算分配、受众定位、出价策略依赖经验判断，缺乏数据支撑，ROI 波动大。</p>
              </div>
            </div>
            <div class="pd-pain">
              <div class="pd-pain-num">03</div>
              <div class="pd-pain-body">
                <div class="pd-pain-title">数据资产未利用</div>
                <p class="pd-pain-desc">历史投放数据、优质素材模板、成功策略均沉淀在本地文件中，无法复用和积累。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ 产品策略 -->
    <section class="pd-section pd-alt">
      <div class="section-inner">
        <p class="section-label reveal">产品策略</p>
        <h2 class="section-headline reveal reveal-delay-1">四期路线，<br>从工具到平台。</h2>
        <div class="pd-roadmap reveal reveal-delay-2">
          <div class="pd-rphase pd-rphase-done">
            <div class="pd-rphase-dot"></div>
            <div class="pd-rphase-tag">Phase 1 · 已上线</div>
            <div class="pd-rphase-name">内容资产化</div>
            <p class="pd-rphase-desc">SKU 录入、模板管理、文案 + 配图生成、效果回填</p>
          </div>
          <div class="pd-rline pd-rline-done"></div>
          <div class="pd-rphase pd-rphase-done">
            <div class="pd-rphase-dot"></div>
            <div class="pd-rphase-tag">Phase 2 · 已上线</div>
            <div class="pd-rphase-name">投放可控化</div>
            <p class="pd-rphase-desc">护栏配置、投放报告、诊断分析、优化方案</p>
          </div>
          <div class="pd-rline"></div>
          <div class="pd-rphase">
            <div class="pd-rphase-dot pd-rdot-future"></div>
            <div class="pd-rphase-tag pd-rtag-future">Phase 3 · 规划中</div>
            <div class="pd-rphase-name">ROI 归因</div>
            <p class="pd-rphase-desc">AB 实验框架、精准归因、策略沉淀</p>
          </div>
          <div class="pd-rline"></div>
          <div class="pd-rphase">
            <div class="pd-rphase-dot pd-rdot-future"></div>
            <div class="pd-rphase-tag pd-rtag-future">Phase 4 · 规划中</div>
            <div class="pd-rphase-name">多模态升级</div>
            <p class="pd-rphase-desc">视频素材生成、跨平台投放、智能选品</p>
          </div>
        </div>
        <div class="pd-bizmodel reveal reveal-delay-3">
          <div class="pd-biz-label">商业模式</div>
          <div class="pd-biz-tiers">
            <div class="pd-biz-tier">
              <div class="pd-biz-name">免费版</div>
              <div class="pd-biz-desc">基础功能限额，获取潜在客户</div>
            </div>
            <div class="pd-biz-tier pd-biz-hl">
              <div class="pd-biz-name">订阅版</div>
              <div class="pd-biz-desc">完整功能 + 数据沉淀，月付制</div>
            </div>
            <div class="pd-biz-tier">
              <div class="pd-biz-name">超量付费</div>
              <div class="pd-biz-desc">超出额度按量计费，弹性扩容</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 系统设计 -->
    <section class="pd-section">
      <div class="section-inner">
        <p class="section-label reveal">系统设计</p>
        <h2 class="section-headline reveal reveal-delay-1">多 Agent 协同，<br>三层记忆架构。</h2>

        <!-- Agent 架构 -->
        <div class="pd-arch reveal reveal-delay-2">
          <div class="pd-arch-caption">Agent 协同架构</div>
          <div class="pd-arch-diagram">
            <div class="pd-arch-main-row">
              <div class="pd-arch-node pd-arch-main">
                <div class="pd-anode-icon">⚙</div>
                <div class="pd-anode-name">主 Agent</div>
                <div class="pd-anode-desc">工作流管理 · 任务分发 · 上下文维护</div>
              </div>
            </div>
            <div class="pd-arch-tree">
              <div class="pd-arch-vline"></div>
              <div class="pd-arch-hline"></div>
            </div>
            <div class="pd-arch-experts-row">
              <div class="pd-arch-node pd-arch-expert">
                <div class="pd-anode-icon">✎</div>
                <div class="pd-anode-name">内容生成 Agent</div>
                <div class="pd-anode-desc">文案 · 配图 · 素材包</div>
              </div>
              <div class="pd-arch-node pd-arch-expert">
                <div class="pd-anode-icon">◎</div>
                <div class="pd-anode-name">投放决策 Agent</div>
                <div class="pd-anode-desc">预算分配 · 受众定位 · 出价</div>
              </div>
              <div class="pd-arch-node pd-arch-expert">
                <div class="pd-anode-icon">◈</div>
                <div class="pd-anode-name">数据分析 Agent</div>
                <div class="pd-anode-desc">效果监测 · 诊断 · 优化建议</div>
              </div>
            </div>
          </div>
        </div>

        <!-- 三层记忆 -->
        <div class="pd-memory reveal reveal-delay-3">
          <div class="pd-arch-caption">三层记忆架构</div>
          <div class="pd-mem-layers">
            <div class="pd-mem-layer pd-mem-l1">
              <div class="pd-mem-name">Session Memory</div>
              <div class="pd-mem-desc">当前对话上下文 · 任务状态 · 临时变量</div>
            </div>
            <div class="pd-mem-arrow">↓</div>
            <div class="pd-mem-layer pd-mem-l2">
              <div class="pd-mem-name">Merchant Memory</div>
              <div class="pd-mem-desc">商家 SKU 库 · 素材风格偏好 · 历史投放策略</div>
            </div>
            <div class="pd-mem-arrow">↓</div>
            <div class="pd-mem-layer pd-mem-l3">
              <div class="pd-mem-name">Knowledge Base</div>
              <div class="pd-mem-desc">1万+ 素材库 · 1–2千条策略库 · 敏感词库 · 图片风格库<br>向量 + 混合检索 · AI 初标 + 人工审核</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ 核心功能 -->
    <section class="pd-section pd-alt">
      <div class="section-inner">
        <p class="section-label reveal">核心功能</p>
        <h2 class="section-headline reveal reveal-delay-1">四个模块，<br>覆盖投放全链路。</h2>

        <div class="pd-features">
          <div class="pd-feature reveal">
            <div class="pd-feature-img">
              <div class="pd-img-placeholder">
                <span class="pd-ph-main">截图待补充</span>
                <span class="pd-ph-sub">SKU 录入界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-fnum">01</div>
              <div class="pd-ftitle">SKU 录入</div>
              <p class="pd-fdesc">商家通过结构化表单录入商品信息，系统自动解析并入库，作为后续素材生成的上下文基础。</p>
              <div class="pd-fdecision">
                <div class="pd-fdec-label">设计决策</div>
                <p>表单优于对话：SKU 信息字段明确、结构固定。用多轮对话收集会产生难以维护的状态机，表单一次性提交反而更可靠、更易校验。</p>
              </div>
            </div>
          </div>

          <div class="pd-feature pd-feature-rev reveal">
            <div class="pd-feature-img">
              <div class="pd-img-placeholder">
                <span class="pd-ph-main">截图待补充</span>
                <span class="pd-ph-sub">素材生成界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-fnum">02</div>
              <div class="pd-ftitle">素材生成（文案 + 配图）</div>
              <p class="pd-fdesc">选择 SKU + 投放模板，一键生成完整素材包。通义千问生成文案，万象生成配图，端到端 10 分钟内完成，效率提升 5×。</p>
              <div class="pd-fdecision">
                <div class="pd-fdec-label">设计决策</div>
                <p>从「完全复刻模板图」到「提取风格 + 重新生成」：前者受扩散模型限制准确率低，后者将风格信息结构化为 prompt，结合 System Prompt 优化，准确率从 70% 提升至 98.6%。</p>
              </div>
            </div>
          </div>

          <div class="pd-feature reveal">
            <div class="pd-feature-img">
              <div class="pd-img-placeholder">
                <span class="pd-ph-main">截图待补充</span>
                <span class="pd-ph-sub">投放报告界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-fnum">03</div>
              <div class="pd-ftitle">投放报告</div>
              <p class="pd-fdesc">汇总投放数据，可视化展示 CTR、CVR、ROI 等核心指标，支持 CSV 批量导入历史数据。</p>
              <div class="pd-fdecision">
                <div class="pd-fdec-label">设计决策</div>
                <p>效果数据由商家手动回填而非 API 对接：初期与平台无授权关系，回填成本低、数据可控，且作为 Knowledge Base 的训练素材持续优化模型。</p>
              </div>
            </div>
          </div>

          <div class="pd-feature pd-feature-rev reveal">
            <div class="pd-feature-img">
              <div class="pd-img-placeholder">
                <span class="pd-ph-main">截图待补充</span>
                <span class="pd-ph-sub">投放诊断界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-fnum">04</div>
              <div class="pd-ftitle">投放诊断</div>
              <p class="pd-fdesc">AI 分析当前投放效果，输出结构化诊断报告和优化方案，识别预算分配问题、素材疲劳信号、受众偏移等。</p>
              <div class="pd-fdecision">
                <div class="pd-fdec-label">设计决策</div>
                <p>诊断采用任务式输出而非开放对话：结构化诊断比一问一答更准确，且可溯源到具体数据，避免 AI 幻觉产生不可信的建议。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑥ 关键挑战 -->
    <section class="pd-section">
      <div class="section-inner">
        <p class="section-label reveal">关键挑战</p>
        <h2 class="section-headline reveal reveal-delay-1">三个难题，<br>三次范式转换。</h2>

        <div class="pd-challenges">
          <!-- C1: 架构演进 -->
          <div class="pd-challenge reveal">
            <div class="pd-ch-header">
              <div class="pd-ch-num">01</div>
              <div class="pd-ch-title">架构演进：从硬编码到 FlowEngine 分层</div>
            </div>
            <div class="pd-evolution">
              <div class="pd-evo-step pd-evo-bad">
                <div class="pd-evo-lbl">硬编码阶段</div>
                <p>工作流写死在代码里，每次新需求都要改底层逻辑，多表单串联导致状态混乱，Bug 频发难以维护。</p>
              </div>
              <div class="pd-evo-arr">→</div>
              <div class="pd-evo-step pd-evo-mid">
                <div class="pd-evo-lbl">纯 Agent 阶段</div>
                <p>将所有流程交给 Agent 自主决策，但复杂表单填写（SKU 录入等）AI 幻觉严重，稳定性差，连续多步骤流程容易中断。</p>
              </div>
              <div class="pd-evo-arr">→</div>
              <div class="pd-evo-step pd-evo-good">
                <div class="pd-evo-lbl">FlowEngine 分层</div>
                <p>结构化流程（表单、规则逻辑）由 FlowEngine 确定性执行，开放性分析（诊断、生成建议）交由 Agent 处理，兼顾 AI 灵活性与系统稳定性。</p>
              </div>
            </div>
          </div>

          <!-- C2: 准确率 -->
          <div class="pd-challenge reveal reveal-delay-1">
            <div class="pd-ch-header">
              <div class="pd-ch-num">02</div>
              <div class="pd-ch-title">图片生成准确率：从 70% 到 98.6%</div>
            </div>
            <div class="pd-evolution pd-evolution-2col">
              <div class="pd-evo-step pd-evo-bad">
                <div class="pd-evo-lbl">初版方案</div>
                <p>直接让模型「完全复刻参考图」，受扩散模型特性限制，构图漂移严重、细节还原差，准确率仅 70%，质量不可用。</p>
              </div>
              <div class="pd-evo-arr">→</div>
              <div class="pd-evo-step pd-evo-good">
                <div class="pd-evo-lbl">优化方案</div>
                <p>放弃「复刻」思路，改为：① 从模板提取风格信息（色调、构图、排版规则）结构化为 prompt；② 结合 SKU 素材文案重新生成；③ 优化模型选型 + System Prompt 工程。准确率提升至 98.6%，模型成本同步降低 95%。</p>
              </div>
            </div>
          </div>

          <!-- C3: 对话记录 -->
          <div class="pd-challenge reveal reveal-delay-2">
            <div class="pd-ch-header">
              <div class="pd-ch-num">03</div>
              <div class="pd-ch-title">产品哲学之争：要不要展示对话记录？</div>
            </div>
            <div class="pd-debate">
              <div class="pd-debate-sides">
                <div class="pd-debate-side pd-debate-for">
                  <div class="pd-db-lbl">支持展示</div>
                  <p>增强透明感，用户可以了解 AI 推理过程，有助于建立信任感。</p>
                </div>
                <div class="pd-debate-vs">VS</div>
                <div class="pd-debate-side pd-debate-against">
                  <div class="pd-db-lbl">反对展示</div>
                  <p>产品已有 SKU 库、素材库、策略库作为可溯源的数据基础；系统以任务式主导为核心，原始对话流对用户决策无实质帮助，反而增加认知负担。</p>
                </div>
              </div>
              <div class="pd-debate-result">
                <div class="pd-dr-lbl">最终决策</div>
                <p>不展示对话记录。将 AI 的工作过程转化为结构化的「诊断报告」和「优化建议」，以用户可读的产品形态呈现结果，而非原始对话流。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑦ 结果 -->
    <section class="pd-results">
      <div class="pd-results-inner">
        <p class="section-label reveal" style="color:rgba(255,255,255,0.45)">项目成果</p>
        <h2 class="section-headline reveal reveal-delay-1" style="color:#fff; margin-bottom:56px">数字说话。</h2>
        <div class="pd-results-grid">
          <div class="pd-ri reveal reveal-delay-1"><div class="pd-ri-val">3×</div><div class="pd-ri-lbl">内容生产效率</div></div>
          <div class="pd-ri reveal reveal-delay-2"><div class="pd-ri-val">50→250</div><div class="pd-ri-lbl">周素材产出（条）</div></div>
          <div class="pd-ri reveal reveal-delay-3"><div class="pd-ri-val">98.6%</div><div class="pd-ri-lbl">素材生成准确率</div></div>
          <div class="pd-ri reveal reveal-delay-4"><div class="pd-ri-val">252万</div><div class="pd-ri-lbl">年收入</div></div>
          <div class="pd-ri reveal reveal-delay-5"><div class="pd-ri-val">20家</div><div class="pd-ri-lbl">付费客户</div></div>
          <div class="pd-ri reveal reveal-delay-6"><div class="pd-ri-val">85%+</div><div class="pd-ri-lbl">客户留存率</div></div>
          <div class="pd-ri reveal reveal-delay-1"><div class="pd-ri-val">−95%</div><div class="pd-ri-lbl">模型成本降低</div></div>
        </div>
      </div>
    </section>

    <!-- ⑧ 项目导航 -->
    <div class="pd-proj-nav">
      <a class="pd-pnav-back" href="/projects">← 所有项目</a>
      <a class="pd-pnav-next" href="/projects/jd-promo">
        <span class="pd-pnav-label">下一个项目</span>
        <span class="pd-pnav-title">京东大促互动产品 →</span>
      </a>
    </div>

  </main>
</Layout>

<style>
/* ─── 共用 ─── */
.section-inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 40px;
}
.pd-section { padding: 120px 0; background: var(--bg); }
.pd-alt     { background: var(--bg-alt); }

/* ─── Hero ─── */
.pd-hero {
  background: #0a0a0a;
  padding: 160px 40px 100px;
}
.pd-hero-inner {
  max-width: 1080px;
  margin: 0 auto;
}
.pd-hero-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.pd-htag {
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 100px;
  padding: 4px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  letter-spacing: .3px;
}
.pd-hero-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(52px, 8vw, 96px);
  font-weight: 800;
  color: #fff;
  letter-spacing: -.04em;
  line-height: 1;
  margin-bottom: 20px;
}
.pd-hero-sub {
  font-size: 20px;
  color: rgba(255,255,255,0.45);
  line-height: 1.6;
  margin-bottom: 60px;
}
.pd-hero-metrics {
  display: flex;
  align-items: center;
  gap: 0;
  flex-wrap: wrap;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 36px;
}
.pd-hm {
  padding: 0 32px 0 0;
  flex-shrink: 0;
}
