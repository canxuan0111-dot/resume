---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Tag from '../../components/Tag.astro';
---

<Layout title="AI 轻松投">
  <main class="pd">

    <!-- ① Hero -->
    <section class="pd-hero">
      <div class="pd-inner">
        <div class="pd-hero-tags">
          <Tag label="AI 产品经理" variant="hero" />
          <Tag label="2024.06 – 2025.11" variant="hero" />
          <Tag label="Multi-Agent · RAG · 多模态" variant="hero" />
        </div>
        <h1 class="pd-hero-title">AI 轻松投</h1>
        <p class="pd-hero-sub">小红书电商腰部商家的<br>AI 投放全流程助手</p>
        <div class="pd-hero-rule"></div>
        <div class="pd-hero-stats">
          <div class="pd-stat"><div class="pd-stat-val">3×</div><div class="pd-stat-lbl">效率提升</div></div>
          <div class="pd-stat"><div class="pd-stat-val">98.6%</div><div class="pd-stat-lbl">素材准确率</div></div>
          <div class="pd-stat"><div class="pd-stat-val">252万</div><div class="pd-stat-lbl">年收入</div></div>
          <div class="pd-stat"><div class="pd-stat-val">20家</div><div class="pd-stat-lbl">付费客户</div></div>
          <div class="pd-stat"><div class="pd-stat-val">85%+</div><div class="pd-stat-lbl">客户留存</div></div>
          <div class="pd-stat"><div class="pd-stat-val">−95%</div><div class="pd-stat-lbl">模型成本</div></div>
        </div>
      </div>
    </section>

    <!-- ② 背景与问题 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="背景与问题"
          title="谁在用，<br>为什么需要它？"
        />
        <div class="pd-problem-grid reveal reveal-delay-2">
          <div class="pd-user-card">
            <div class="pd-user-label">目标用户</div>
            <div class="pd-user-name">小红书电商腰部商家<br>年销 500万 – 5000万</div>
            <div class="pd-user-rule"></div>
            <div class="pd-user-market">
              <div>
                <div class="pd-market-val">150–200亿</div>
                <div class="pd-market-lbl">GMV/年·市场规模</div>
              </div>
              <div>
                <div class="pd-market-val">20–50亿</div>
                <div class="pd-market-lbl">服务市场空间</div>
              </div>
            </div>
          </div>
          <div class="pd-pains">
            <div class="pd-pain reveal reveal-delay-2">
              <div class="pd-pain-num">01</div>
              <div>
                <div class="pd-pain-title">内容生产低效</div>
                <p class="pd-pain-desc">一条合格素材需策划、设计、文案多轮协作，周产出仅 50 条，无法覆盖投放消耗。</p>
              </div>
            </div>
            <div class="pd-pain reveal reveal-delay-3">
              <div class="pd-pain-num">02</div>
              <div>
                <div class="pd-pain-title">投放决策碎片化</div>
                <p class="pd-pain-desc">预算分配、受众定位、出价策略依赖经验判断，缺乏数据支撑，ROI 波动大。</p>
              </div>
            </div>
            <div class="pd-pain reveal reveal-delay-4">
              <div class="pd-pain-num">03</div>
              <div>
                <div class="pd-pain-title">数据资产未利用</div>
                <p class="pd-pain-desc">历史投放数据、优质素材模板、成功策略均沉淀在本地文件中，无法复用和积累。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ 产品策略 -->
    <section class="pd-section pd-alt">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="产品策略"
          title="四期路线，<br>从工具到平台。"
        />
        <div class="pd-roadmap reveal reveal-delay-2">
          <div class="pd-phase pd-phase--done">
            <div class="pd-phase-dot"></div>
            <div class="pd-phase-tag">Phase 1 · 已上线</div>
            <div class="pd-phase-name">内容资产化</div>
            <p class="pd-phase-desc">SKU 录入、模板管理、文案 + 配图生成、效果回填</p>
          </div>
          <div class="pd-roadmap-line pd-roadmap-line--done"></div>
          <div class="pd-phase pd-phase--done">
            <div class="pd-phase-dot"></div>
            <div class="pd-phase-tag">Phase 2 · 已上线</div>
            <div class="pd-phase-name">投放可控化</div>
            <p class="pd-phase-desc">护栏配置、投放报告、诊断分析、优化方案</p>
          </div>
          <div class="pd-roadmap-line"></div>
          <div class="pd-phase">
            <div class="pd-phase-dot pd-phase-dot--future"></div>
            <div class="pd-phase-tag pd-phase-tag--future">Phase 3 · 规划中</div>
            <div class="pd-phase-name">ROI 归因</div>
            <p class="pd-phase-desc">AB 实验框架、精准归因、策略沉淀</p>
          </div>
          <div class="pd-roadmap-line"></div>
          <div class="pd-phase">
            <div class="pd-phase-dot pd-phase-dot--future"></div>
            <div class="pd-phase-tag pd-phase-tag--future">Phase 4 · 规划中</div>
            <div class="pd-phase-name">多模态升级</div>
            <p class="pd-phase-desc">视频素材生成、跨平台投放、智能选品</p>
          </div>
        </div>
        <div class="pd-bizmodel reveal reveal-delay-3">
          <div class="pd-biz-eyebrow">商业模式</div>
          <div class="pd-biz-tiers">
            <div class="pd-biz-tier">
              <div class="pd-biz-name">免费版</div>
              <div class="pd-biz-desc">基础功能限额，获取潜在客户</div>
            </div>
            <div class="pd-biz-tier pd-biz-tier--hl">
              <div class="pd-biz-name">订阅版</div>
              <div class="pd-biz-desc">完整功能 + 数据沉淀，月付制</div>
            </div>
            <div class="pd-biz-tier">
              <div class="pd-biz-name">超量付费</div>
              <div class="pd-biz-desc">超出额度按量计费，弹性扩容</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 系统设计 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="系统设计"
          title="多 Agent 协同，<br>三层记忆架构。"
        />

        <div class="pd-arch reveal reveal-delay-2">
          <div class="pd-card-eyebrow">Agent 协同架构</div>
          <div class="pd-arch-diagram">
            <!-- 主 Agent -->
            <div class="pd-arch-main-row">
              <div class="pd-arch-node pd-arch-node--main">
                <div class="pd-node-glyph">⚙</div>
                <div class="pd-node-name">主 Agent</div>
                <div class="pd-node-desc">工作流管理 · 任务分发 · 上下文维护</div>
              </div>
            </div>
            <!-- 连线 -->
            <div class="pd-arch-connector">
              <div class="pd-conn-vline"></div>
              <div class="pd-conn-hline"></div>
            </div>
            <!-- 专家 Agents -->
            <div class="pd-arch-experts">
              <div class="pd-arch-node pd-arch-node--expert">
                <div class="pd-conn-vline-branch"></div>
                <div class="pd-node-glyph">✎</div>
                <div class="pd-node-name">内容生成 Agent</div>
                <div class="pd-node-desc">文案 · 配图 · 素材包</div>
              </div>
              <div class="pd-arch-node pd-arch-node--expert">
                <div class="pd-conn-vline-branch"></div>
                <div class="pd-node-glyph">◎</div>
                <div class="pd-node-name">投放决策 Agent</div>
                <div class="pd-node-desc">预算分配 · 受众定位 · 出价</div>
              </div>
              <div class="pd-arch-node pd-arch-node--expert">
                <div class="pd-conn-vline-branch"></div>
                <div class="pd-node-glyph">◈</div>
                <div class="pd-node-name">数据分析 Agent</div>
                <div class="pd-node-desc">效果监测 · 诊断 · 优化建议</div>
              </div>
            </div>
          </div>
        </div>

        <div class="pd-memory reveal reveal-delay-3">
          <div class="pd-card-eyebrow">三层记忆架构</div>
          <div class="pd-mem-layers">
            <div class="pd-mem-layer pd-mem-layer--1">
              <div class="pd-mem-name">Session Memory</div>
              <div class="pd-mem-desc">当前对话上下文 · 任务状态 · 临时变量</div>
            </div>
            <div class="pd-mem-arrow">↓</div>
            <div class="pd-mem-layer pd-mem-layer--2">
              <div class="pd-mem-name">Merchant Memory</div>
              <div class="pd-mem-desc">商家 SKU 库 · 素材风格偏好 · 历史投放策略</div>
            </div>
            <div class="pd-mem-arrow">↓</div>
            <div class="pd-mem-layer pd-mem-layer--3">
              <div class="pd-mem-name">Knowledge Base</div>
              <div class="pd-mem-desc">1万+ 素材库 · 1–2千条策略库 · 敏感词库 · 图片风格库 · 向量 + 混合检索 · AI 初标 + 人工审核</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ 核心功能 -->
    <section class="pd-section pd-alt">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="核心功能"
          title="四个模块，<br>覆盖投放全链路。"
        />

        <div class="pd-features">
          <div class="pd-feature reveal">
            <div class="pd-feature-media">
              <div class="pd-placeholder">
                <span class="pd-placeholder-main">截图待补充</span>
                <span class="pd-placeholder-sub">SKU 录入界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-feature-num">01</div>
              <h3 class="pd-feature-title">SKU 录入</h3>
              <p class="pd-feature-desc">商家通过结构化表单录入商品信息，系统自动解析并入库，作为后续素材生成的上下文基础。</p>
              <div class="pd-decision">
                <div class="pd-decision-label">设计决策</div>
                <p>表单优于对话：SKU 信息字段明确、结构固定。用多轮对话收集会产生难以维护的状态机，表单一次性提交反而更可靠、更易校验。</p>
              </div>
            </div>
          </div>

          <div class="pd-feature pd-feature--rev reveal">
            <div class="pd-feature-media">
              <div class="pd-placeholder">
                <span class="pd-placeholder-main">截图待补充</span>
                <span class="pd-placeholder-sub">素材生成界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-feature-num">02</div>
              <h3 class="pd-feature-title">素材生成（文案 + 配图）</h3>
              <p class="pd-feature-desc">选择 SKU + 投放模板，一键生成完整素材包。通义千问生成文案，万象生成配图，端到端 10 分钟内完成，效率提升 5×。</p>
              <div class="pd-decision">
                <div class="pd-decision-label">设计决策</div>
                <p>从「完全复刻模板图」到「提取风格 + 重新生成」：前者受扩散模型限制准确率低，后者将风格信息结构化为 prompt，结合 System Prompt 优化，准确率从 70% 提升至 98.6%。</p>
              </div>
            </div>
          </div>

          <div class="pd-feature reveal">
            <div class="pd-feature-media">
              <div class="pd-placeholder">
                <span class="pd-placeholder-main">截图待补充</span>
                <span class="pd-placeholder-sub">投放报告界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-feature-num">03</div>
              <h3 class="pd-feature-title">投放报告</h3>
              <p class="pd-feature-desc">汇总投放数据，可视化展示 CTR、CVR、ROI 等核心指标，支持 CSV 批量导入历史数据。</p>
              <div class="pd-decision">
                <div class="pd-decision-label">设计决策</div>
                <p>效果数据由商家手动回填而非 API 对接：初期与平台无授权关系，回填成本低、数据可控，且作为 Knowledge Base 的训练素材持续优化模型。</p>
              </div>
            </div>
          </div>

          <div class="pd-feature pd-feature--rev reveal">
            <div class="pd-feature-media">
              <div class="pd-placeholder">
                <span class="pd-placeholder-main">截图待补充</span>
                <span class="pd-placeholder-sub">投放诊断界面</span>
              </div>
            </div>
            <div class="pd-feature-body">
              <div class="pd-feature-num">04</div>
              <h3 class="pd-feature-title">投放诊断</h3>
              <p class="pd-feature-desc">AI 分析当前投放效果，输出结构化诊断报告和优化方案，识别预算分配问题、素材疲劳信号、受众偏移等。</p>
              <div class="pd-decision">
                <div class="pd-decision-label">设计决策</div>
                <p>诊断采用任务式输出而非开放对话：结构化诊断比一问一答更准确，且可溯源到具体数据，避免 AI 幻觉产生不可信的建议。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑥ 关键挑战 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="关键挑战"
          title="三个难题，<br>三次范式转换。"
        />

        <!-- 挑战 1 -->
        <div class="pd-challenge reveal">
          <div class="pd-ch-head">
            <span class="pd-ch-num">01</span>
            <h3 class="pd-ch-title">架构演进：从硬编码到 FlowEngine 分层</h3>
          </div>
          <div class="pd-evolution">
            <div class="pd-evo-step pd-evo-step--bad">
              <div class="pd-evo-label">硬编码阶段</div>
              <p>工作流写死在代码里，每次新需求都要改底层逻辑，多表单串联导致状态混乱，Bug 频发难以维护。</p>
            </div>
            <div class="pd-evo-arrow">→</div>
            <div class="pd-evo-step pd-evo-step--mid">
              <div class="pd-evo-label">纯 Agent 阶段</div>
              <p>将所有流程交给 Agent 自主决策，但复杂表单填写（SKU 录入等）AI 幻觉严重，稳定性差，连续多步骤流程容易中断。</p>
            </div>
            <div class="pd-evo-arrow">→</div>
            <div class="pd-evo-step pd-evo-step--good">
              <div class="pd-evo-label">FlowEngine 分层</div>
              <p>结构化流程（表单、规则逻辑）由 FlowEngine 确定性执行，开放性分析（诊断、生成建议）交由 Agent 处理，兼顾 AI 灵活性与系统稳定性。</p>
            </div>
          </div>
        </div>

        <!-- 挑战 2 -->
        <div class="pd-challenge reveal reveal-delay-1">
          <div class="pd-ch-head">
            <span class="pd-ch-num">02</span>
            <h3 class="pd-ch-title">图片生成准确率：从 70% 到 98.6%</h3>
          </div>
          <div class="pd-evolution pd-evolution--2col">
            <div class="pd-evo-step pd-evo-step--bad">
              <div class="pd-evo-label">初版方案</div>
              <p>直接让模型「完全复刻参考图」，受扩散模型特性限制，构图漂移严重、细节还原差，准确率仅 70%，质量不可用。</p>
            </div>
            <div class="pd-evo-arrow">→</div>
            <div class="pd-evo-step pd-evo-step--good">
              <div class="pd-evo-label">优化方案</div>
              <p>放弃「复刻」思路，改为：① 从模板提取风格信息（色调、构图、排版规则）结构化为 prompt；② 结合 SKU 素材文案重新生成；③ 优化模型选型 + System Prompt 工程。准确率提升至 98.6%，模型成本同步降低 95%。</p>
            </div>
          </div>
        </div>

        <!-- 挑战 3 -->
        <div class="pd-challenge reveal reveal-delay-2">
          <div class="pd-ch-head">
            <span class="pd-ch-num">03</span>
            <h3 class="pd-ch-title">产品哲学之争：要不要展示对话记录？</h3>
          </div>
          <div class="pd-debate">
            <div class="pd-debate-sides">
              <div class="pd-debate-side pd-debate-side--for">
                <div class="pd-debate-label">支持展示</div>
                <p>增强透明感，用户可以了解 AI 推理过程，有助于建立信任感。</p>
              </div>
              <div class="pd-debate-vs">VS</div>
              <div class="pd-debate-side pd-debate-side--against">
                <div class="pd-debate-label">反对展示</div>
                <p>产品已有 SKU 库、素材库、策略库作为可溯源的数据基础；系统以任务式主导为核心，原始对话流对用户决策无实质帮助，反而增加认知负担。</p>
              </div>
            </div>
            <div class="pd-debate-result">
              <div class="pd-debate-result-label">最终决策</div>
              <p>不展示对话记录。将 AI 的工作过程转化为结构化的「诊断报告」和「优化建议」，以用户可读的产品形态呈现结果，而非原始对话流。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑦ 结果 -->
    <section class="pd-results">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="项目成果"
          title="数字说话。"
          theme="dark"
        />
        <div class="pd-results-grid">
          <div class="pd-result reveal reveal-delay-1"><div class="pd-result-val">3×</div><div class="pd-result-lbl">内容生产效率</div></div>
          <div class="pd-result reveal reveal-delay-2"><div class="pd-result-val">50→250</div><div class="pd-result-lbl">周素材产出（条）</div></div>
          <div class="pd-result reveal reveal-delay-3"><div class="pd-result-val">98.6%</div><div class="pd-result-lbl">素材生成准确率</div></div>
          <div class="pd-result reveal reveal-delay-4"><div class="pd-result-val">252万</div><div class="pd-result-lbl">年收入</div></div>
          <div class="pd-result reveal reveal-delay-5"><div class="pd-result-val">20家</div><div class="pd-result-lbl">付费客户</div></div>
          <div class="pd-result reveal reveal-delay-6"><div class="pd-result-val">85%+</div><div class="pd-result-lbl">客户留存率</div></div>
          <div class="pd-result reveal reveal-delay-1"><div class="pd-result-val">−95%</div><div class="pd-result-lbl">模型成本降低</div></div>
        </div>
      </div>
    </section>

    <!-- ⑧ 项目导航 -->
    <div class="pd-proj-nav">
      <a class="pd-nav-back" href="/projects">← 所有项目</a>
      <a class="pd-nav-next" href="/projects/jd-promo">
        <span class="pd-nav-next-hint">下一个项目</span>
        <span class="pd-nav-next-name">京东大促互动产品 →</span>
      </a>
    </div>

  </main>
</Layout>

<style>
/* ─── 布局基础 ─── */
.pd-inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 40px;
}

.pd-section {
  padding: 120px 0;
  background: var(--bg);
}

.pd-alt {
  background: var(--bg-alt);
}

/* ─── Hero ─── */
.pd-hero {
  background: var(--canvas-dark);
  padding: 160px 40px 100px;
}

.pd-hero-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 32px;
}

.pd-hero-title {
  font-family: var(--font-display);
  font-size: clamp(56px, 9vw, 112px);
  font-weight: 800;
  letter-spacing: -.04em;
  line-height: .96;
  color: var(--text-inv);
  margin-bottom: 24px;
}

.pd-hero-sub {
  font-size: 20px;
  color: var(--muted-inv);
  line-height: 1.6;
  margin-bottom: 56px;
}

.pd-hero-rule {
  height: 1px;
  background: var(--border-inv);
  margin-bottom: 40px;
}

.pd-hero-stats {
  display: flex;
  gap: 48px;
  flex-wrap: wrap;
}

.pd-stat-val {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  color: var(--text-inv);
  letter-spacing: -.02em;
  margin-bottom: 4px;
}

.pd-stat-lbl {
  font-size: 12px;
  color: var(--muted-inv);
}

/* ─── 背景与问题 ─── */
.pd-problem-grid {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 24px;
  align-items: start;
}

.pd-user-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px 24px;
  position: sticky;
  top: 80px;
}

.pd-user-label {
