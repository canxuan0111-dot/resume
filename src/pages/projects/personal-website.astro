---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Tag from '../../components/Tag.astro';
import CtaButton from '../../components/CtaButton.astro';
---

<Layout title="个人网站 · Vibe Coding 实践" navPill={true}>
  <main class="pd">

    <!-- ① Hero -->
    <section class="pd-hero">
      <img src="/personal-website.jpg" alt="" class="pd-hero-bg-img" aria-hidden="true" />
      <div class="pd-hero-overlay"></div>
      <div class="pd-hero-content">
        <div class="pd-hero-bl pd-ha pd-ha-bl">
          <div class="pd-hero-tags">
            <Tag label="Vibe Coding" variant="hero" />
            <Tag label="2025" variant="hero" />
            <Tag label="Astro 5 · 纯 CSS · 零框架" variant="hero" />
          </div>
          <h1 class="pd-hero-title">个人网站</h1>
          <p class="pd-hero-sub">用 AI 协作，48 小时构建专业级个人网站</p>
          <div class="pd-hero-rule"></div>
          <div class="pd-hero-stats">
            <div class="pd-stat"><div class="pd-stat-val">2天</div><div class="pd-stat-lbl">从零到上线</div></div>
            <div class="pd-stat"><div class="pd-stat-val">6版</div><div class="pd-stat-lbl">迭代里程碑</div></div>
            <div class="pd-stat"><div class="pd-stat-val">7页</div><div class="pd-stat-lbl">完整内容页</div></div>
            <div class="pd-stat"><div class="pd-stat-val">0</div><div class="pd-stat-lbl">UI 框架依赖</div></div>
          </div>
        </div>
        <div class="pd-hero-scroll pd-ha pd-ha-scroll" aria-hidden="true">
          <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
          <div class="scroll-arrows"><span></span><span></span></div>
          <span class="scroll-label">SCROLL</span>
        </div>
      </div>
    </section>

    <!-- ② 核心命题 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="核心命题"
          title="AI 负责执行，<br>我负责判断。"
        />
        <div class="pd-premise-grid reveal reveal-delay-2">
          <div class="pd-premise-card">
            <div class="pd-premise-label">项目上下文</div>
            <div class="pd-premise-item">
              <span class="pd-premise-key">类型</span>
              <span class="pd-premise-val">个人作品 · Vibe Coding 实践</span>
            </div>
            <div class="pd-premise-item">
              <span class="pd-premise-key">技术栈</span>
              <span class="pd-premise-val">Astro 5 · 纯 CSS · TypeScript</span>
            </div>
            <div class="pd-premise-item">
              <span class="pd-premise-key">起点</span>
              <span class="pd-premise-val">散落的 HTML 原型 + 参考设计</span>
            </div>
            <div class="pd-premise-item">
              <span class="pd-premise-key">终点</span>
              <span class="pd-premise-val">生产级静态站点，Vercel 部署</span>
            </div>
          </div>
          <div class="pd-premise-body">
            <div class="pd-premise-point reveal reveal-delay-2">
              <div class="pd-premise-num">01</div>
              <div>
                <div class="pd-premise-title">这个网站本身就是方法论的证明</div>
                <p class="pd-premise-desc">大多数设计师的个人网站是"结果展示"。这个网站同时也是"过程证明"——它记录了一套 AI 协作的工作方式，如何在没有工程师参与的情况下，完成从架构设计到生产上线的完整交付。</p>
              </div>
            </div>
            <div class="pd-premise-point reveal reveal-delay-3">
              <div class="pd-premise-num">02</div>
              <div>
                <div class="pd-premise-title">优势不在于 Prompt，在于判断力</div>
                <p class="pd-premise-desc">当前 AI 工具对 Prompt 本身的优化已经足够成熟。真正的差异来自上层的决策：选什么技术栈、如何定义设计系统、用什么粒度拆解任务。AI 是执行引擎，判断力才是核心变量。</p>
              </div>
            </div>
            <div class="pd-premise-point reveal reveal-delay-4">
              <div class="pd-premise-num">03</div>
              <div>
                <div class="pd-premise-title">结构化思维让 AI 产出可预期</div>
                <p class="pd-premise-desc">将 DESIGN_SYSTEM.md 作为每次会话的 context 锚点，将页面拆解为明确的 section 容器，将技术选型约束在 AI 熟悉的边界内——这些前期决策直接决定了 AI 生成代码的质量上限。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ 决策链 -->
    <section class="pd-section pd-alt">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="关键决策"
          title="三个选择，<br>决定了最终质量。"
        />
        <div class="pd-decisions">

          <div class="pd-decision-card reveal">
            <div class="pd-dc-num">01</div>
            <div class="pd-dc-body">
              <h3 class="pd-dc-title">从优秀 Template 改造，而非从零开始</h3>
              <div class="pd-dc-compare">
                <div class="pd-dc-option pd-dc-option--skip">
                  <div class="pd-dc-opt-label">放弃方案</div>
                  <p>从空白文件出发，让 AI 从零生成全部布局代码。每次会话要同时处理"布局决策"和"内容填充"，认知成本高，输出质量不稳定。</p>
                </div>
                <div class="pd-dc-arrow">→</div>
                <div class="pd-dc-option pd-dc-option--pick">
                  <div class="pd-dc-opt-label">实际决策</div>
                  <p>找到设计语言对齐的优质 template 作为改造基础。布局骨架已确立，AI 的生成能量集中在内容质量、交互细节和定制化改造上，产出质量显著提升。</p>
                </div>
              </div>
            </div>
          </div>

          <div class="pd-decision-card reveal reveal-delay-1">
            <div class="pd-dc-num">02</div>
            <div class="pd-dc-body">
              <h3 class="pd-dc-title">迁移到 Astro 5，散落 HTML 变成可维护的系统</h3>
              <div class="pd-dc-compare">
                <div class="pd-dc-option pd-dc-option--skip">
                  <div class="pd-dc-opt-label">原有状态</div>
                  <p>多个独立 HTML 文件，样式无法复用，无路由系统，每次修改导航/头部都要逐文件手动同步，维护成本随页数线性增长。</p>
                </div>
                <div class="pd-dc-arrow">→</div>
                <div class="pd-dc-option pd-dc-option--pick">
                  <div class="pd-dc-opt-label">实际决策</div>
                  <p>迁移到 Astro 5：pages 目录即路由，Layout 组件统一管理全局 shell，scoped style 隔离各页面样式。AI 生成的 .astro 文件结构可预期，context 窗口利用率高。</p>
                </div>
              </div>
            </div>
          </div>

          <div class="pd-decision-card reveal reveal-delay-2">
            <div class="pd-dc-num">03</div>
            <div class="pd-dc-body">
              <h3 class="pd-dc-title">零 UI 框架，自建 CSS Token 系统</h3>
              <div class="pd-dc-compare">
                <div class="pd-dc-option pd-dc-option--skip">
                  <div class="pd-dc-opt-label">考虑方案</div>
                  <p>引入 Tailwind CSS 或 shadcn/ui。AI 熟悉这些工具，生成速度快——但输出会依赖 class 查找表，设计定制空间受限，最终视觉会趋向模板化。</p>
                </div>
                <div class="pd-dc-arrow">→</div>
                <div class="pd-dc-option pd-dc-option--pick">
                  <div class="pd-dc-opt-label">实际决策</div>
                  <p>全部使用 scoped CSS + CSS 变量 token。纯 CSS 让 AI 直接理解设计意图而非查找 class 名；自建 token 系统让每次会话都基于同一份"规格书"，保证全站一致性。</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ④ 迭代时间线 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="迭代过程"
          title="48 小时，<br>6 个里程碑。"
        />
        <div class="pd-timeline reveal reveal-delay-2">
          <div class="pd-tl-item">
            <div class="pd-tl-dot pd-tl-dot--done"></div>
            <div class="pd-tl-content">
              <div class="pd-tl-version">v1</div>
              <div class="pd-tl-name">网站架构</div>
              <p class="pd-tl-desc">确定页面结构（index / resume / contact / projects / articles），技术栈选型，Vercel 部署接入，建立开发环境。</p>
              <div class="pd-tl-key">关键决策：技术栈 + 路由结构</div>
            </div>
          </div>
          <div class="pd-tl-line pd-tl-line--done"></div>

          <div class="pd-tl-item">
            <div class="pd-tl-dot pd-tl-dot--done"></div>
            <div class="pd-tl-content">
              <div class="pd-tl-version">v2</div>
              <div class="pd-tl-name">内容规划与容器</div>
              <p class="pd-tl-desc">定义每个页面的 section 层级，信息架构与导航逻辑，建立页面容器占位，完成整体信息流的验证。</p>
              <div class="pd-tl-key">关键决策：信息架构 + 内容优先级</div>
            </div>
          </div>
          <div class="pd-tl-line pd-tl-line--done"></div>

          <div class="pd-tl-item">
            <div class="pd-tl-dot pd-tl-dot--done"></div>
            <div class="pd-tl-content">
              <div class="pd-tl-version">v3</div>
              <div class="pd-tl-name">设计里程碑（首页）</div>
              <p class="pd-tl-desc">首页完整视觉方案落地：深色 Hero + 视差滚动、白色交替楼层、Syne 字体大字排版、红色 CTA 圆圈。确立全站视觉基调。</p>
              <div class="pd-tl-key">关键决策：视觉语言 + 交互风格</div>
            </div>
          </div>
          <div class="pd-tl-line pd-tl-line--done"></div>

          <div class="pd-tl-item">
            <div class="pd-tl-dot pd-tl-dot--done"></div>
            <div class="pd-tl-content">
              <div class="pd-tl-version">v4</div>
              <div class="pd-tl-name">设计系统提炼与全站应用</div>
              <p class="pd-tl-desc">从首页提炼 CSS token，整理 DESIGN_SYSTEM.md 文档，封装 SectionHeader / CtaButton / Tag 等复用组件，在所有页面统一应用。</p>
              <div class="pd-tl-key">关键决策：设计 token 化 + 组件边界</div>
            </div>
          </div>
          <div class="pd-tl-line pd-tl-line--done"></div>

          <div class="pd-tl-item">
            <div class="pd-tl-dot pd-tl-dot--done"></div>
            <div class="pd-tl-content">
              <div class="pd-tl-version">v5</div>
              <div class="pd-tl-name">真实内容填充</div>
              <p class="pd-tl-desc">项目详情页 × 3、技术文章 × 3、简历页、联系页全部完成。每个页面遵循设计系统，复用已有组件和 CSS 模式。</p>
              <div class="pd-tl-key">关键决策：内容深度 + 展示粒度</div>
            </div>
          </div>
          <div class="pd-tl-line pd-tl-line--done"></div>

          <div class="pd-tl-item">
            <div class="pd-tl-dot pd-tl-dot--done"></div>
            <div class="pd-tl-content">
              <div class="pd-tl-version">v6</div>
              <div class="pd-tl-name">检查与修复</div>
              <p class="pd-tl-desc">跨页面一致性走查，动效细节优化（scroll reveal 时机、parallax 速度），响应式断点修复，Lighthouse 性能检测与优化。</p>
              <div class="pd-tl-key">关键决策：质量标准 + 发布时机</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 装饰图 + 设计系统 -->
    <div class="pd-deco-wrapper">
      <section class="pd-deco-img" id="pd-deco-img">
        <div class="pd-deco-code">
          <div class="pd-code-block">
            <div class="pd-code-line"><span class="tok-comment">/* DESIGN_SYSTEM.md → CSS tokens */</span></div>
            <div class="pd-code-line"><span class="tok-selector">:root</span> <span class="tok-punct">{</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--bg</span><span class="tok-punct">:</span> <span class="tok-val">#ffffff</span><span class="tok-punct">;</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--bg-alt</span><span class="tok-punct">:</span> <span class="tok-val">#f0f0f0</span><span class="tok-punct">;</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--canvas-dark</span><span class="tok-punct">:</span> <span class="tok-val">#0a0a0a</span><span class="tok-punct">;</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--accent</span><span class="tok-punct">:</span> <span class="tok-val">#0062ff</span><span class="tok-punct">;</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--red</span><span class="tok-punct">:</span> <span class="tok-val">#f9442c</span><span class="tok-punct">;</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--font-display</span><span class="tok-punct">:</span> <span class="tok-str">'Syne'</span><span class="tok-punct">, sans-serif;</span></div>
            <div class="pd-code-line pd-code-indent"><span class="tok-prop">--radius-lg</span><span class="tok-punct">:</span> <span class="tok-val">16px</span><span class="tok-punct">;</span></div>
            <div class="pd-code-line"><span class="tok-punct">}</span></div>
          </div>
        </div>
      </section>

      <!-- ⑤ 设计系统 -->
      <section class="pd-section pd-alt pd-over">
        <div class="pd-inner">
          <SectionHeader
            eyebrow="设计系统"
            title="规格书即<br>AI 的记忆。"
          />

          <div class="pd-ds-grid reveal reveal-delay-2">
            <!-- 颜色 token -->
            <div class="pd-ds-card">
              <div class="pd-card-eyebrow">颜色 Token</div>
              <div class="pd-color-swatches">
                <div class="pd-swatch">
                  <div class="pd-swatch-color" style="background:#0a0a0a; border:1px solid #333;"></div>
                  <div class="pd-swatch-name">canvas-dark</div>
                  <div class="pd-swatch-use">Hero · 深色楼层</div>
                </div>
                <div class="pd-swatch">
                  <div class="pd-swatch-color" style="background:#ffffff; border:1px solid #e0e0e0;"></div>
                  <div class="pd-swatch-name">bg</div>
                  <div class="pd-swatch-use">正文楼层底色</div>
                </div>
                <div class="pd-swatch">
                  <div class="pd-swatch-color" style="background:#f0f0f0; border:1px solid #e0e0e0;"></div>
                  <div class="pd-swatch-name">bg-alt</div>
                  <div class="pd-swatch-use">交替楼层底色</div>
                </div>
                <div class="pd-swatch">
                  <div class="pd-swatch-color" style="background:#0062ff;"></div>
                  <div class="pd-swatch-name">accent</div>
                  <div class="pd-swatch-use">眉标 · 链接 · 指示器</div>
                </div>
                <div class="pd-swatch">
                  <div class="pd-swatch-color" style="background:#f9442c;"></div>
                  <div class="pd-swatch-name">red</div>
                  <div class="pd-swatch-use">CTA 圆圈</div>
                </div>
              </div>
            </div>

            <!-- 字体系统 -->
            <div class="pd-ds-card">
              <div class="pd-card-eyebrow">字体系统</div>
              <div class="pd-type-demo">
                <div class="pd-type-row">
                  <div class="pd-type-sample pd-type-display">Syne</div>
                  <div class="pd-type-meta">
                    <div class="pd-type-name">Display Font</div>
                    <div class="pd-type-use">标题 · 大数字 · 名字 · 导航</div>
                    <div class="pd-type-weight">400 · 600 · 700 · 800</div>
                  </div>
                </div>
                <div class="pd-type-divider"></div>
                <div class="pd-type-row">
                  <div class="pd-type-sample pd-type-body">Inter</div>
                  <div class="pd-type-meta">
                    <div class="pd-type-name">Body Font</div>
                    <div class="pd-type-use">正文 · 描述 · 标签 · 中文内容</div>
                    <div class="pd-type-weight">400 · 500 · 600 · 700</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 组件 -->
          <div class="pd-ds-components reveal reveal-delay-3">
            <div class="pd-card-eyebrow" style="margin-bottom:24px;">复用组件</div>
            <div class="pd-comp-list">
              <div class="pd-comp-item">
                <div class="pd-comp-name">SectionHeader</div>
                <p class="pd-comp-desc">眉标 + 标题 + 副标题三层结构，支持 editorial / bold 字重变体，light / dark 主题，内置 scroll reveal 动效。</p>
              </div>
              <div class="pd-comp-item">
                <div class="pd-comp-name">CtaButton</div>
                <p class="pd-comp-desc">胶囊按钮 + 红色旋转箭头圆圈，hover 时箭头旋转动效，支持 dark / light 变体。</p>
              </div>
              <div class="pd-comp-item">
                <div class="pd-comp-name">Tag</div>
                <p class="pd-comp-desc">4 种变体：skill（白色胶囊）· hero（深色背景玻璃态）· tech（灰色）· metric（绿色）。</p>
              </div>
              <div class="pd-comp-item">
                <div class="pd-comp-name">ArticleCard</div>
                <p class="pd-comp-desc">封面渐变 + meta 信息 + 标题卡片，支持 soon 标记即将发布的内容。</p>
              </div>
            </div>
          </div>

          <!-- DESIGN_SYSTEM.md 的价值 -->
          <div class="pd-ds-insight reveal reveal-delay-4">
            <div class="pd-insight-label">核心洞察</div>
            <p>DESIGN_SYSTEM.md 不只是文档，它是 AI 的"外部记忆"。每次开启新会话时将其注入 context，AI 就能在不了解之前对话的情况下，生成与全站视觉语言一致的代码。<strong>设计系统文档化的本质，是让 AI 协作可以跨会话延续。</strong></p>
          </div>
        </div>
      </section>
    </div><!-- /pd-deco-wrapper -->

    <!-- ⑥ 核心挑战 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="核心挑战"
          title="三个难题，<br>三种应对方式。"
        />

        <!-- 挑战 1 -->
        <div class="pd-challenge reveal">
          <div class="pd-ch-head">
            <span class="pd-ch-num">01</span>
            <h3 class="pd-ch-title">多会话一致性：AI 怎么记住上次的决定？</h3>
          </div>
          <div class="pd-evolution pd-evolution--2col">
            <div class="pd-evo-step pd-evo-step--bad">
              <div class="pd-evo-label">问题</div>
              <p>AI 无法跨会话记忆。每次新对话，它对之前的颜色系统、间距规范、组件结构一无所知，容易生成"风格漂移"的代码，需要大量手工修正。</p>
            </div>
            <div class="pd-evo-arrow">→</div>
            <div class="pd-evo-step pd-evo-step--good">
              <div class="pd-evo-label">应对方式</div>
              <p>将 DESIGN_SYSTEM.md 作为每次会话的必读 context，配合现有页面代码片段作为风格参考。AI 有了"规格书"，生成代码自然对齐全站风格，无需逐条纠正。</p>
            </div>
          </div>
        </div>

        <!-- 挑战 2 -->
        <div class="pd-challenge reveal reveal-delay-1">
          <div class="pd-ch-head">
            <span class="pd-ch-num">02</span>
            <h3 class="pd-ch-title">复杂动效实现：有状态的交互 AI 能处理吗？</h3>
          </div>
          <div class="pd-evolution pd-evolution--2col">
            <div class="pd-evo-step pd-evo-step--bad">
              <div class="pd-evo-label">问题</div>
              <p>parallax 视差、sticky 压叠滑入、IntersectionObserver scroll reveal、导航 pill 收缩/展开——这些动效涉及 DOM 状态管理和 CSS 层叠关系，直接让 AI "写一个 parallax" 容易出现层级混乱。</p>
            </div>
            <div class="pd-evo-arrow">→</div>
            <div class="pd-evo-step pd-evo-step--good">
              <div class="pd-evo-label">应对方式</div>
              <p>先讨论 HTML 结构和 CSS position 方案，再生成 script。将"结构"与"行为"分两步处理，每步 diff 范围小且可审查。复杂的 sticky 压叠问题通过 isolation: isolate 包裹 wrapper 解决，AI 理解后一次生成正确代码。</p>
            </div>
          </div>
        </div>

        <!-- 挑战 3 -->
        <div class="pd-challenge reveal reveal-delay-2">
          <div class="pd-ch-head">
            <span class="pd-ch-num">03</span>
