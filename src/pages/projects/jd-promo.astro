<script>
  // ── 装饰图 scale 入场 ──
  const decoSection = document.getElementById('pd-deco-img');
  if (decoSection) {
    const decoObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          decoSection.classList.add('deco-visible');
          decoObs.unobserve(decoSection);
        }
      });
    }, { threshold: 0.1 });
    decoObs.observe(decoSection);
  }

  const nav  = document.getElementById('main-nav')!;
  const hero = document.querySelector('.pd-hero') as HTMLElement;

  function updateNav() {
    nav.classList.toggle('nav-hero', hero.getBoundingClientRect().bottom > 60);
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });
</script>
