---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Tag from '../../components/Tag.astro';
import CtaButton from '../../components/CtaButton.astro';
---

<Layout title="京东大促互动产品" navPill={true}>
  <main class="pd">

    <!-- ① Hero -->
    <section class="pd-hero">

      <!-- 背景图 -->
      <img src="/jd-hero.jpg" alt="" class="pd-hero-bg-img" aria-hidden="true" />

      <!-- 遮罩：左侧 + 底部加深 -->
      <div class="pd-hero-overlay"></div>

      <!-- 内容层 -->
      <div class="pd-hero-content">

        <!-- 居中：标签 + 标题 + 副标题 + 数据 -->
        <div class="pd-hero-bl pd-ha pd-ha-bl">
          <div class="pd-hero-tags">
            <Tag label="游戏化设计" variant="hero" />
            <Tag label="2021 – 2023" variant="hero" />
            <Tag label="双11 · 618 · 年货节" variant="hero" />
          </div>
          <h1 class="pd-hero-title">京东大促<br>互动产品</h1>
          <p class="pd-hero-sub">T 级大促全周期互动设计<br>三次完整项目复盘</p>
          <div class="pd-hero-rule"></div>
          <div class="pd-hero-stats">
            <div class="pd-stat"><div class="pd-stat-val">8350w</div><div class="pd-stat-lbl">累计参与 UV（618）</div></div>
            <div class="pd-stat"><div class="pd-stat-val">1753w</div><div class="pd-stat-lbl">日均 DAU（年货节）</div></div>
            <div class="pd-stat"><div class="pd-stat-val">70.12%</div><div class="pd-stat-lbl">次日复访率</div></div>
            <div class="pd-stat"><div class="pd-stat-val">2866w</div><div class="pd-stat-lbl">累计分享 UV（双11）</div></div>
            <div class="pd-stat"><div class="pd-stat-val">+89%</div><div class="pd-stat-lbl">参与 UV 同比增长</div></div>
          </div>
        </div>

        <!-- 右下角：滚动引导 -->
        <div class="pd-hero-scroll pd-ha pd-ha-scroll" aria-hidden="true">
          <div class="scroll-mouse">
            <div class="scroll-wheel"></div>
          </div>
          <div class="scroll-arrows">
            <span></span>
            <span></span>
          </div>
          <span class="scroll-label">SCROLL</span>
        </div>

      </div>
    </section>

    <!-- ② 背景与目标 -->
    <section class="pd-section">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="背景与目标"
          title="同一个问题，<br>三次深度解答。"
        />
        <div class="pd-overview reveal reveal-delay-2">
          <div class="pd-overview-problems">
            <div class="pd-prob">
              <div class="pd-prob-num">01</div>
              <div>
                <div class="pd-prob-title">参与深度不足</div>
                <p class="pd-prob-desc">大促高流量场景下，用户一次性点击多、长线参与少，粘性与复访均难持续。</p>
              </div>
            </div>
            <div class="pd-prob">
              <div class="pd-prob-num">02</div>
              <div>
                <div class="pd-prob-title">设计价值难量化</div>
                <p class="pd-prob-desc">设计动作与业务结果缺乏直连路径，参与 UV、分享 UV、复访率等指标难以归因到具体设计决策。</p>
              </div>
            </div>
            <div class="pd-prob">
              <div class="pd-prob-num">03</div>
              <div>
                <div class="pd-prob-title">方法难以复用</div>
                <p class="pd-prob-desc">每次大促单独摸索，策略设计缺少可沉淀的框架，跨项目经验流失严重。</p>
              </div>
            </div>
          </div>

          <div class="pd-timeline">
            <div class="pd-tl-item">
              <div class="pd-tl-dot"></div>
              <div class="pd-tl-tag">双11 · 2022</div>
              <div class="pd-tl-name">热爱穿行记</div>
              <p class="pd-tl-desc">古风穿越主题，长线粘性探索</p>
            </div>
            <div class="pd-tl-line"></div>
            <div class="pd-tl-item">
              <div class="pd-tl-dot"></div>
              <div class="pd-tl-tag">618 · 2022</div>
              <div class="pd-tl-name">热爱奇旅</div>
              <p class="pd-tl-desc">权重拆解，可验证增长路径</p>
            </div>
            <div class="pd-tl-line"></div>
            <div class="pd-tl-item">
              <div class="pd-tl-dot"></div>
              <div class="pd-tl-tag">年货节 · 2023</div>
              <div class="pd-tl-name">炸年兽</div>
              <p class="pd-tl-desc">稳态交付，下沉增量探索</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ 项目一：热爱穿行记 -->
    <section class="pd-section pd-alt" id="p1">
      <div class="pd-inner">
        <div class="pd-proj-eyebrow reveal">
          <span class="pd-proj-num-label">项目一</span>
          <span class="pd-proj-sep">·</span>
          <span class="pd-proj-period">双11 · 2022</span>
        </div>
        <div class="pd-proj-hero reveal reveal-delay-1">
          <h2 class="pd-proj-title">热爱穿行记</h2>
          <div class="pd-proj-tags">
            <Tag label="古风穿越" variant="tech" />
            <Tag label="长线粘性" variant="tech" />
          </div>
        </div>

        <div class="pd-proj-body">
          <div class="pd-proj-media reveal reveal-delay-2">
            <img src="/jd-cover01.jpg" alt="热爱穿行记 · 古风穿越视觉" class="pd-proj-img" />
          </div>
          <div class="pd-proj-detail reveal reveal-delay-3">
            <div class="pd-subsection">
              <div class="pd-sub-label">背景与目标</div>
              <ul class="pd-list">
                <li>目标：提升累计参与 UV、分享 UV、活动长线粘性。</li>
                <li>挑战：长周期活动中，如何让用户持续回来而不是一次性流失。</li>
              </ul>
            </div>
            <div class="pd-subsection">
              <div class="pd-sub-label">策略设计</div>
              <ul class="pd-list">
                <li>以"古风穿越"主题建立叙事记忆点，增强故事驱动参与。</li>
                <li>搭建游戏化核心循环：任务获取资源 → 抽奖/推进进度 → 解锁新内容 → 再投入。</li>
                <li>强化主操作反馈：自增长、抽奖、穿越等节点即时反馈，提升行为确定感。</li>
                <li>通过角色状态与任务触发机制提升复访/裂变相关行为（召回、回流、持续玩）。</li>
                <li>设置阶段目标与进度感（章节/朝代/里程碑），降低中途流失。</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="pd-kpi-grid reveal reveal-delay-2">
          <div class="pd-kpi">
            <div class="pd-kpi-val">2866w</div>
            <div class="pd-kpi-lbl">累计分享 UV</div>
            <div class="pd-kpi-delta">同比 +13.3%</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+173%</div>
            <div class="pd-kpi-lbl">签到总人数</div>
            <div class="pd-kpi-delta">同比 · 环比 +168%</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+167%</div>
            <div class="pd-kpi-lbl">满 23 天签到用户</div>
            <div class="pd-kpi-delta">同比 · 环比 +32.1%</div>
          </div>
          <div class="pd-kpi pd-kpi--note">
            <div class="pd-kpi-val">穿越主题</div>
            <div class="pd-kpi-lbl">用户反馈</div>
            <div class="pd-kpi-delta">角色互动意愿较强</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 项目二：热爱奇旅 -->
    <section class="pd-section" id="p2">
      <div class="pd-inner">
        <div class="pd-proj-eyebrow reveal">
          <span class="pd-proj-num-label">项目二</span>
          <span class="pd-proj-sep">·</span>
          <span class="pd-proj-period">618 · 2022</span>
        </div>
        <div class="pd-proj-hero reveal reveal-delay-1">
          <h2 class="pd-proj-title">热爱奇旅</h2>
          <div class="pd-proj-tags">
            <Tag label="权重拆解" variant="tech" />
            <Tag label="可验证增长" variant="tech" />
          </div>
        </div>

        <div class="pd-proj-body pd-proj-body--rev">
          <div class="pd-proj-media reveal reveal-delay-2">
            <img src="/jd-cover02.jpg" alt="热爱奇旅 · 互动业务场景" class="pd-proj-img" />
          </div>
          <div class="pd-proj-detail reveal reveal-delay-3">
            <div class="pd-subsection">
              <div class="pd-sub-label">背景与目标</div>
              <ul class="pd-list">
                <li>目标：提升参与规模与互动粘性，并建立可量化验证路径。</li>
                <li>挑战：设计价值容易"可感知但难量化"，指标归因缺失。</li>
              </ul>
            </div>
            <div class="pd-subsection">
              <div class="pd-sub-label">策略设计</div>
              <ul class="pd-list">
                <li>拆解参与/任务/发起/分享四条主路径，建立权重框架。</li>
                <li>将游戏化机制映射到各路径：任务阶梯、阶段奖励、可视进度、峰值反馈。</li>
                <li>结合变量奖励与关键时段触发，提升短中期活跃与回访。</li>
                <li>策略动作与埋点方案同步推进，保障后续可验证。</li>
                <li>复盘时强调"数据回看驱动下一轮优化"。</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="pd-kpi-grid pd-kpi-grid--8 reveal reveal-delay-2">
          <div class="pd-kpi pd-kpi--accent">
            <div class="pd-kpi-val">8350w</div>
            <div class="pd-kpi-lbl">累计参与 UV</div>
            <div class="pd-kpi-delta">同比 +89%</div>
          </div>
          <div class="pd-kpi pd-kpi--accent">
            <div class="pd-kpi-val">1172.5w</div>
            <div class="pd-kpi-lbl">日均 DAU</div>
            <div class="pd-kpi-delta">同比 +65%</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">61.4%</div>
            <div class="pd-kpi-lbl">次日复访率</div>
            <div class="pd-kpi-delta">同比 +4.8%</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">101.7w</div>
            <div class="pd-kpi-lbl">分享 UV</div>
            <div class="pd-kpi-delta">同比 +63%</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">44次</div>
            <div class="pd-kpi-lbl">人均参与次数</div>
            <div class="pd-kpi-delta">同比 +31次</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">7.45</div>
            <div class="pd-kpi-lbl">人均分享次数</div>
            <div class="pd-kpi-delta">同比 +1.84次</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+5%</div>
            <div class="pd-kpi-lbl">分享率</div>
            <div class="pd-kpi-delta">同比提升</div>
          </div>
          <div class="pd-kpi pd-kpi--note">
            <div class="pd-kpi-val">指标权重</div>
            <div class="pd-kpi-lbl">核心结论</div>
            <div class="pd-kpi-delta">埋点机制可稳定复用</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ⑤ 项目三：炸年兽 -->
    <section class="pd-section pd-alt" id="p3">
      <div class="pd-inner">
        <div class="pd-proj-eyebrow reveal">
          <span class="pd-proj-num-label">项目三</span>
          <span class="pd-proj-sep">·</span>
          <span class="pd-proj-period">年货节 · 2023</span>
        </div>
        <div class="pd-proj-hero reveal reveal-delay-1">
          <h2 class="pd-proj-title">炸年兽</h2>
          <div class="pd-proj-tags">
            <Tag label="稳态交付" variant="tech" />
            <Tag label="下沉增量" variant="tech" />
          </div>
        </div>

        <div class="pd-proj-body">
          <div class="pd-proj-media reveal reveal-delay-2">
            <img src="/jd-cover03.jpg" alt="炸年兽 · 互动业务场景" class="pd-proj-img" />
          </div>
          <div class="pd-proj-detail reveal reveal-delay-3">
            <div class="pd-subsection">
              <div class="pd-sub-label">背景与目标</div>
              <ul class="pd-list">
                <li>目标：资源与周期受限下，维稳大盘并探索下沉增量。</li>
                <li>挑战：上线稳定性、体验质量、增长探索三者并行。</li>
              </ul>
            </div>
            <div class="pd-subsection">
              <div class="pd-sub-label">策略设计</div>
              <ul class="pd-list">
                <li>复用成熟内核 + 主题升级，缩短方案落地路径。</li>
                <li>下沉化改造：触点简化、利益感知强化、裂变/小游戏组合。</li>
                <li>加入游戏化留存机制：签到节奏、阶段挑战、任务后置引导与回流触点。</li>
                <li>通过社交协作/助力与轻竞争机制，提升传播与二次进入动机。</li>
                <li>通过策略-埋点-复盘闭环，持续校准方向。</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="pd-kpi-grid pd-kpi-grid--8 reveal reveal-delay-2">
          <div class="pd-kpi pd-kpi--accent">
            <div class="pd-kpi-val">1753w</div>
            <div class="pd-kpi-lbl">日均 DAU</div>
            <div class="pd-kpi-delta">同比 +136.3%</div>
          </div>
          <div class="pd-kpi pd-kpi--accent">
            <div class="pd-kpi-val">70.12%</div>
            <div class="pd-kpi-lbl">次日复访率</div>
            <div class="pd-kpi-delta">同比 +10%</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+1.44%</div>
            <div class="pd-kpi-lbl">环比双11 DAU</div>
            <div class="pd-kpi-delta">稳定提升</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">29.79次</div>
            <div class="pd-kpi-lbl">人均参与次数</div>
            <div class="pd-kpi-delta">&nbsp;</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+40%</div>
            <div class="pd-kpi-lbl">人均抽奖次数</div>
            <div class="pd-kpi-delta">同比提升</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+57%</div>
            <div class="pd-kpi-lbl">人均参与次数</div>
            <div class="pd-kpi-delta">同比（核心操作优化）</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">+9.8%</div>
            <div class="pd-kpi-lbl">引流店铺/会场 UV</div>
            <div class="pd-kpi-delta">同比提升</div>
          </div>
          <div class="pd-kpi">
            <div class="pd-kpi-val">72%</div>
            <div class="pd-kpi-lbl">新手引导留存率</div>
            <div class="pd-kpi-delta">环比 +7.2%</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 装饰图 + 方法论楼层 包在 wrapper 内，限制 sticky 范围 -->
    <div class="pd-deco-wrapper">
      <section class="pd-deco-img" id="pd-deco-img">
        <img src="/jd-deco.jpg" alt="" class="pd-deco-full-img" />
      </section>

    <!-- ⑥ 跨项目方法论 -->
    <section class="pd-section pd-over">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="方法论沉淀"
          title="可复用的游戏化<br>设计框架。"
        />
        <div class="pd-methods reveal reveal-delay-2">
          <div class="pd-method">
            <div class="pd-method-num">01</div>
            <div class="pd-method-name">目标拆解</div>
            <p class="pd-method-desc">业务目标拆到行为指标，设计动作有锚点。</p>
          </div>
          <div class="pd-method">
            <div class="pd-method-num">02</div>
            <div class="pd-method-name">游戏循环</div>
            <p class="pd-method-desc">目标—行动—反馈—奖励—再行动，建立持续参与闭环。</p>
          </div>
          <div class="pd-method">
            <div class="pd-method-num">03</div>
            <div class="pd-method-name">反馈分层</div>
            <p class="pd-method-desc">基础反馈/强反馈/峰值反馈组合拉动参与与复访。</p>
          </div>
          <div class="pd-method">
            <div class="pd-method-num">04</div>
            <div class="pd-method-name">进度与挑战</div>
            <p class="pd-method-desc">通过进度可视化与阶段挑战降低流失，提升完成动机。</p>
          </div>
          <div class="pd-method">
            <div class="pd-method-num">05</div>
            <div class="pd-method-name">社交驱动</div>
            <p class="pd-method-desc">助力、分享、组队等轻社交机制放大传播与回流。</p>
          </div>
          <div class="pd-method">
            <div class="pd-method-num">06</div>
            <div class="pd-method-name">证据闭环</div>
            <p class="pd-method-desc">先设计可验证，再复盘可复用。策略-埋点-复盘形成正向循环。</p>
          </div>
          <div class="pd-method">
            <div class="pd-method-num">07</div>
            <div class="pd-method-name">协同推进</div>
            <p class="pd-method-desc">策略、交互、视觉、研发并线协同，减少链路断层。</p>
          </div>
        </div>
      </div>
    </section>
    </div><!-- /pd-deco-wrapper -->

    <!-- ⑦ 结果 -->
    <section class="pd-results">
      <div class="pd-inner">
        <SectionHeader
          eyebrow="三次项目综合成果"
          title="数字说话。"
          weight="editorial"
          theme="dark"
        />
        <div class="pd-results-grid">
          <div class="pd-result reveal reveal-delay-1"><div class="pd-result-val">8350w</div><div class="pd-result-lbl">累计参与 UV（奇旅）</div></div>
          <div class="pd-result reveal reveal-delay-2"><div class="pd-result-val">+89%</div><div class="pd-result-lbl">参与 UV 同比增长</div></div>
          <div class="pd-result reveal reveal-delay-3"><div class="pd-result-val">1753w</div><div class="pd-result-lbl">日均 DAU（炸年兽）</div></div>
          <div class="pd-result reveal reveal-delay-4"><div class="pd-result-val">70.12%</div><div class="pd-result-lbl">次日复访率（炸年兽）</div></div>
          <div class="pd-result reveal reveal-delay-5"><div class="pd-result-val">2866w</div><div class="pd-result-lbl">累计分享 UV（穿行记）</div></div>
          <div class="pd-result reveal reveal-delay-6"><div class="pd-result-val">+136%</div><div class="pd-result-lbl">DAU 同比增长</div></div>
          <div class="pd-result reveal reveal-delay-1"><div class="pd-result-val">44次</div><div class="pd-result-lbl">人均参与次数（奇旅）</div></div>
          <div class="pd-result reveal reveal-delay-2"><div class="pd-result-val">+173%</div><div class="pd-result-lbl">签到人数同比（穿行记）</div></div>
        </div>
        <div class="pd-results-cta">
          <CtaButton href="/contact" label="联系我" variant="light" />
          <CtaButton href="/resume" label="查看完整简历" variant="light" />
        </div>
      </div>
    </section>

    <!-- ⑧ 项目导航 -->
    <div class="pd-proj-nav">
      <a class="pd-nav-back" href="/projects">← 所有项目</a>
      <a class="pd-nav-next" href="/projects/ai-ad-assistant">
        <span class="pd-nav-next-hint">上一个项目</span>
        <span class="pd-nav-next-name">← AI 轻松投</span>
      </a>
    </div>

  </main>
</Layout>

<style>
/* ─── 布局基础 ─── */
.pd-inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 40px;
}

.pd-section {
  padding: 120px 0;
  background: var(--bg);
}

.pd-alt {
  background: var(--bg-alt);
}

/* ─── Hero ─── */
.pd-hero {
  position: relative;
  background: var(--canvas-dark);
  height: 100vh;
  min-height: 640px;
  overflow: hidden;
}

.pd-hero-bg-img {
